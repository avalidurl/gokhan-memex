---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostTitle from '@/components/PostTitle.astro'
import PortfolioBoard from '@/components/PortfolioBoard.astro'
import { getCollection } from 'astro:content'

const essays = (await getCollection('blog'))
  .filter(
    (p) =>
      !p.data.draft &&
      p.data.category.toLowerCase() !== 'interviews' &&
      p.data.category !== 'Links'
  )
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })

// Project register — every live project, one ruled cell each. All URLs
// verified live 2026-07-17. Ordered: agent-native products, data/research,
// culture, then local project files.
const projects = [
  { name: 'Ishtar', desc: 'agent-native courtship venue — agents court, humans meet', where: 'ishtar.numetal.xyz', href: 'https://ishtar.numetal.xyz' },
  { name: 'CURB', desc: 'agent↔agent inference clearing rail, USDC over x402', where: 'curb.numetal.xyz', href: 'https://curb.numetal.xyz' },
  { name: 'HeartBench', desc: 'which model is the best date — public leaderboard', where: 'ishtar.numetal.xyz/heartbench', href: 'https://ishtar.numetal.xyz/heartbench/' },
  { name: 'The Window', desc: 'scarce visibility board — $50, 24h, ten slots', where: 'ishtar.numetal.xyz/window', href: 'https://ishtar.numetal.xyz/window/' },
  { name: 'x402-econ', desc: 'measuring & forecasting the machine-payments economy', where: 'gokhan.vc — the report', href: 'https://gokhan.vc/blog/x402-economy-july-2026' },
  { name: 'tickerline', desc: 'Claude Code status line as a ticker tape — audited on ClaudeLines', where: 'claudelines.com', href: 'https://claudelines.com/statuslines/tickerline' },
  { name: 'Numetal', desc: 'the studio — agent accelerator, on Base', where: 'numetal.xyz', href: 'https://numetal.xyz' },
  { name: 'CLINAMEN / $UBU', desc: 'pataphysical fiction, filed on-chain', where: 'ubu.numetal.xyz', href: 'https://ubu.numetal.xyz' },
  { name: 'CCRU archive', desc: 'ccru.net preserved — 101 pages, mirrored', where: 'ccru.numetal.xyz', href: 'https://ccru.numetal.xyz' },
  { name: 'feedhub', desc: 'newsletter & feed gateway — email + XMTP, one dispatch', where: 'api.gokhan.vc', href: 'https://api.gokhan.vc/feed.xml' },
  { name: 'Agent Bounty', desc: 'project file — agent bounty experiments', where: 'filed here', href: '/projects/agent-bounty/' },
  { name: 'Market Cap Tracker', desc: 'project file — live market caps', where: 'filed here', href: '/projects/market-cap-tracker/' },
  { name: 'S&P 100 CapEx Dashboard', desc: 'project file — capex through the index', where: 'filed here', href: '/projects/sp100-capex-dashboard/' },
  { name: 'Biases & Fallacies Lab', desc: 'project file — interactive reasoning lab', where: 'filed here', href: '/projects/biases-fallacies-lab/' },
]

// Project index — the stacked table box: INDEX opens the full project list,
// the rest jump straight out to the live products. URLs verified live 2026-07-21.
const projectIndex = [
  { no: '01', name: 'INDEX', note: 'all project files, filed here', href: '/projects/', external: false },
  { no: '02', name: 'CURB', note: 'agent↔agent inference clearing rail', href: 'https://curb.numetal.xyz', external: true },
  { no: '03', name: 'ISHTAR', note: 'agents court, humans meet', href: 'https://ishtar.numetal.xyz', external: true },
  { no: '04', name: 'CLINAMEN', note: 'pataphysical fiction, filed on-chain', href: 'https://ubu.numetal.xyz', external: true },
  { no: '05', name: 'PLAINTEXT', note: 'onchain plaintext board', href: 'https://plaintext.numetal.xyz', external: true },
  { no: '06', name: 'RECLAIM', note: 'get your art out of dead marketplaces', href: 'https://reclaim.numetal.xyz', external: true },
]

---

<BaseLayout
  title="Gökhan Turhan"
  description="Full-stack builder — one person, a fleet of agents. Agent-native venues, rails, and benchmarks live in production on x402: Ishtar, CURB, HeartBench. Journal, CV, publishing."
>
  <div class="ds">
    <!-- Masthead — the filed title block, boxed like a bureau document. -->
    <header class="mast">
      <div class="mast-title">
        <h1 class="h">Gökhan Turhan</h1>
        <div class="sub">Full-stack builder · fintech × AI × agent-native markets</div>
        <div class="stamp">Live in production — taking real machine payments</div>
      </div>
      <div class="mast-row">
        <div class="mast-cell"><a href="/journal/">Read the journal →</a></div>
        <div class="mast-cell">Contact:
          <a href="https://x.com/goekhan" target="_blank" rel="noopener">X</a> ·
          <a href="https://t.me/goekhanturhan" target="_blank" rel="noopener">Telegram</a> ·
          <a href="https://linkedin.com/in/goekhanturhan" target="_blank" rel="noopener">LinkedIn</a> ·
          <a href="mailto:contact@gokhan.vc">Email</a>
        </div>
      </div>
    </header>

    <section class="abstract">
      <p class="lead">
        I'm a <b>full-stack builder</b> — one person, a fleet of agents, everything
        shipped end to end. I design the product, write the code, wire the payments,
        run the security program, and operate what ships: Ishtar, a venue where agents
        court and humans meet; CURB, a rail where agents trade inference for USDC;
        HeartBench, HeartPrefs, and the pipes that meter the x402 economy. All of it is
        <b>live, in production, taking real machine payments</b>. Fintech is still the
        substrate — custody, tokenization, market structure — I've just stopped
        explaining it in decks and started clearing it in prod. I also make conceptual
        art; it keeps me honest about naming and compression.
      </p>
      <p class="p">
        What I want more of is <b>acceleration you can weigh</b>: gigawatts, foundries,
        compute, mass to orbit. Hard tech, deep tech, manufacturing, spaceflight —
        capacity, not adjectives; the base the big problems don't get solved without.
        Governance should compete for that base like any other vendor: jurisdictions
        running different rules, rewarded on outcomes, not paperwork theater. My corner
        of it is the market plumbing — software that buys, sells, and settles with
        other software, fast enough to keep up with the factories we still have to
        build.
      </p>
    </section>

    <div class="dither dgap"></div>
    <PortfolioBoard />

    <div class="dither dgap"></div>
    <section class="pindex-section">
      <div class="idxh">Project index</div>
      <nav class="pindex" aria-label="Project index">
        {projectIndex.map((it) => (
          <a
            class="pirow"
            href={it.href}
            target={it.external ? '_blank' : undefined}
            rel={it.external ? 'noopener' : undefined}
          >
            <span class="pi-no">{it.no}</span>
            <span class="pi-name">{it.name}</span>
            <span class="pi-note">{it.note}</span>
            <span class="pi-arrow" aria-hidden="true">{it.external ? '↗' : '→'}</span>
          </a>
        ))}
      </nav>
    </section>

    <div class="dither dgap"></div>
    <section class="register">
      <div class="idxh">Project register — filed &amp; live</div>
      <div class="grid">
        {projects.map((pr, i) => (
          <a
            class="cell"
            href={pr.href}
            target={pr.href.startsWith('http') ? '_blank' : undefined}
            rel={pr.href.startsWith('http') ? 'noopener' : undefined}
          >
            <div class="k">{String(i + 1).padStart(2, '0')} · {pr.where}</div>
            <div class="v">{pr.name}<small>{pr.desc}</small></div>
          </a>
        ))}
      </div>
      <a class="more" href="/projects/">All project files →</a>
    </section>

    {essays.length > 0 && (
      <>
        <div class="dither dgap"></div>
        <section class="recent">
          <div class="idxh">Recent from the journal</div>
          <ul class="rlist">
            {essays.map((post) => (
              <li>
                <a href={`/journal/${post.slug}/`}>
                  <PostTitle title={post.data.title} class="rt" />
                  <span class="rd">{fmt(post.data.publishDate)}</span>
                </a>
              </li>
            ))}
          </ul>
          <a class="more" href="/journal/">All essays →</a>
        </section>
      </>
    )}
  </div>

  <style>
    .ds { padding: 24px 34px 48px; color: var(--ink); }

    /* Masthead — boxed filed title block, ubu register. */
    .mast { border: 2px solid var(--ink); padding: 0; }
    .mast-title { padding: 1.5rem 1.1rem 1.2rem; }
    .mast-title .h {
      font-size: clamp(26px, 5.5vw, 44px); font-weight: 700;
      letter-spacing: .02em; line-height: 1.05; margin: 0; text-align: left;
    }
    .mast-title .sub {
      margin-top: .6rem; font-size: 12px; letter-spacing: .18em;
      text-transform: uppercase; color: var(--dim);
    }
    .stamp {
      display: inline-block; border: 2px solid var(--ink);
      padding: .32rem .7rem; margin-top: 1rem;
      font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
      transform: rotate(-1.4deg);
    }
    .mast-row {
      display: flex; justify-content: space-between; flex-wrap: wrap;
      border-top: 1px solid var(--ink);
    }
    .mast-cell {
      padding: .6rem 1.1rem; font-size: 11px; letter-spacing: .12em;
      text-transform: uppercase; color: var(--dim);
    }
    .mast-cell + .mast-cell { border-left: 1px solid var(--ink); }
    .mast-cell a { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }

    /* Abstract — the lede paragraphs under the masthead. */
    .abstract { max-width: 72ch; margin: 1.7rem 0 0; }
    .lead { font-size: 15px; line-height: 1.7; margin: 0; color: var(--ink); max-width: 72ch; }
    .lead b, .p b { font-weight: 700; }
    .p {
      font-size: 15px; line-height: 1.7; margin-top: 18px; color: var(--dim);
      border-left: 2px solid var(--ink); padding-left: 18px; max-width: 72ch;
    }

    .dither {
      height: 0; margin: 14px 0;
      border-top: 1px solid var(--ink);
      background-image: none; opacity: 1;
    }
    .dgap { margin: 36px 0 22px; }

    .idxh {
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .22em; margin-bottom: 10px; text-align: left;
      border-bottom: 2px solid var(--ink); padding-bottom: .35rem;
    }

    /* Project index — a small stacked ledger table; INDEX opens the full list. */
    .pindex-section { max-width: 100%; }
    .pindex { border: 2px solid var(--ink); margin-top: 2px; }
    .pirow {
      display: grid;
      grid-template-columns: 3rem minmax(7.5rem, max-content) 1fr 1.4rem;
      gap: 16px; align-items: baseline;
      padding: .72rem .9rem;
      border-bottom: 1px solid var(--ink);
      text-decoration: none; color: var(--ink);
    }
    .pirow:last-child { border-bottom: 0; }
    .pirow:hover { background: var(--faint); }
    .pirow:hover .pi-name { text-decoration: underline; text-underline-offset: 2px; }
    .pi-no { font-family: var(--font-mono); font-size: 11px; color: var(--dim); letter-spacing: .08em; }
    .pi-name { font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: .1em; }
    .pi-note { font-size: 13px; color: var(--dim); }
    .pi-arrow { text-align: right; color: var(--dim); font-size: 13px; }

    /* Project register — fully-boxed ledger grid, ubu §1 spec style. */
    .register { max-width: 100%; }
    .grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      border: 2px solid var(--ink); margin-top: 2px;
    }
    .cell {
      border: 1px solid var(--ink); padding: .8rem .85rem; min-height: 5.6rem;
      display: block; text-decoration: none; color: var(--ink);
    }
    .cell:hover { background: var(--faint); }
    .cell:hover .v { text-decoration: underline; text-underline-offset: 2px; }
    .cell .k {
      font-family: var(--font-mono); font-size: 10px; letter-spacing: .14em;
      text-transform: uppercase; color: var(--dim); margin-bottom: .45rem;
    }
    .cell .v { font-size: 15px; font-weight: 700; line-height: 1.25; }
    .cell .v small {
      display: block; margin-top: .35rem; font-size: 11.5px; font-weight: 400;
      color: var(--dim); line-height: 1.45; letter-spacing: 0; text-transform: none;
    }

    .more { display: inline-block; margin-top: 16px; font-size: 13px; color: var(--dim); text-decoration: underline; text-underline-offset: 2px; }
    .more:hover { color: var(--ink); }

    /* Recent journal — ruled ledger rows. */
    .recent { max-width: 72ch; margin: 0; }
    .recent .rlist { list-style: none; padding: 0; margin: 4px 0 0; }
    .recent li a {
      display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
      padding: 10px 8px; margin: 0 -8px; border-bottom: 1px solid var(--ink);
      text-decoration: none; color: var(--ink);
    }
    .recent li a:hover { background: var(--faint); }
    .recent li a:hover .rt { text-decoration: underline; text-underline-offset: 2px; }
    .recent .rd { font-family: var(--font-mono); font-size: 12px; color: var(--dim); white-space: nowrap; }

    @media (max-width: 820px) {
      .ds { padding: 16px 20px 40px; }
      .grid { grid-template-columns: 1fr; }
      .pirow { grid-template-columns: 2.4rem 1fr auto; gap: 12px; }
      .pi-note { display: none; }
    }
  </style>
</BaseLayout>
