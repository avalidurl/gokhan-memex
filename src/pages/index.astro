---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostTitle from '@/components/PostTitle.astro'
import { getCollection } from 'astro:content'

const essays = (await getCollection('blog'))
  .filter(
    (p) =>
      !p.data.draft &&
      p.data.category.toLowerCase() !== 'interviews' &&
      p.data.category !== 'Links'
  )
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })

const index = [
  { k: 'Journal', d: 'essays, notes & dispatches', href: '/journal/', v: '/journal', ext: false },
  { k: 'Atelier Gökhan', d: 'the venture studio', href: 'https://gokhan.vc/', v: 'gokhan.vc', ext: true },
  { k: 'Ishtar', d: 'agentic dating', href: 'https://ishtar.numetal.xyz/', v: 'ishtar.numetal.xyz', ext: true, live: true },
  { k: 'Numetal Lab', d: 'agent accelerator studio', href: 'https://numetal.xyz/', v: 'numetal.xyz', ext: true },
  { k: 'CV', d: 'the long version', href: '/cv/', v: '/cv', ext: false },
]
---

<BaseLayout
  title="Gökhan Turhan"
  description="Full-spectrum growth operator across fintech infrastructure, AI-native tooling, and tokenized markets. Journal, studios, CV, newsletters."
>
  <div class="ds">
    <div class="meta">Gökhan Turhan · operator · fintech × AI × tokenized markets</div>
    <div class="dither"></div>

    <div class="grid">
      <div class="main">
        <h1 class="h">Gökhan Turhan</h1>
        <p class="lead">
          Full-spectrum growth operator across <b>fintech infrastructure, AI-native
          tooling, and tokenized markets</b>. Builds websites, prototypes, content, and
          growth engines — with code, not just slide decks.
        </p>
        <div class="def">
          I care most about getting to <b>abundant energy and real industrial scale</b>
          fast: power, manufacturing, compute, and the global problems that don't get
          solved without that base. Governance should compete — let jurisdictions try
          different rules and reward outcomes, not paperwork theater.
        </div>
        <p class="p">
          Fintech and payments are where I actually work — custody, tokenization, DeFi
          mechanics, market structure — and the mess around shipping it: partners,
          distribution, institutional story. I own <b>ship + sell</b>: priorities like a
          PM, outreach like BD, technical writing and comms like DevRel. I also make
          conceptual art; it keeps me honest about naming and compression.
        </p>
        <div class="cta">
          <a class="btn" href="/journal/">Read the journal →</a>
          <span class="note">contact:
            <a href="https://x.com/goekhan" target="_blank" rel="noopener">X</a> ·
            <a href="https://t.me/goekhanturhan" target="_blank" rel="noopener">Telegram</a> ·
            <a href="https://linkedin.com/in/goekhanturhan" target="_blank" rel="noopener">LinkedIn</a> ·
            <a href="mailto:contact@gokhan.vc">email</a>
          </span>
        </div>
      </div>

      <aside class="side">
        <div class="idxh">Index</div>
        <div class="dot"></div>
        <div class="idx">
          {index.map((r) => (
            <a
              class="ix"
              href={r.href}
              target={r.ext ? '_blank' : undefined}
              rel={r.ext ? 'noopener noreferrer' : undefined}
            >
              <span class="ixl"><span class="k">{r.k}</span>{r.live && <span class="live">live</span>}<span class="d"> — {r.d}</span></span>
              <span class="v">{r.v} {r.ext ? '↗' : '→'}</span>
            </a>
          ))}
        </div>
      </aside>
    </div>

    {essays.length > 0 && (
      <>
        <div class="dither dgap"></div>
        <section class="recent">
          <div class="idxh">Recent from the journal</div>
          <ul class="rlist">
            {essays.map((post) => (
              <li>
                <a href={`/journal/${post.slug}/`}>
                  <PostTitle title={post.data.title} class="rt" />
                  <span class="rd">{fmt(post.data.publishDate)}</span>
                </a>
              </li>
            ))}
          </ul>
          <a class="more" href="/journal/">All essays →</a>
        </section>
      </>
    )}
  </div>

  <style>
    .ds { padding: 20px 34px 48px; color: hsl(var(--foreground)); }
    .meta {
      font-family: "Courier New", ui-monospace, monospace;
      font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
      color: hsl(var(--muted-foreground));
    }
    .dither {
      height: 11px; opacity: .42; margin: 14px 0;
      background-image: radial-gradient(hsl(var(--foreground)) .62px, transparent .72px);
      background-size: 3px 3px;
    }
    .dgap { margin: 36px 0 22px; }
    .grid { display: grid; grid-template-columns: 1.35fr 1fr; gap: 46px; align-items: start; }
    .h { font-size: clamp(1.7rem, 4.5vw, 2rem); font-weight: 700; letter-spacing: -.02em; line-height: 1.06; }
    .lead { font-size: 16px; line-height: 1.55; margin-top: 15px; max-width: 56ch; color: hsl(var(--foreground)); }
    .lead b, .p b, .def b { font-weight: 700; }
    .def {
      border-left: 2px solid hsl(var(--foreground)); padding: 4px 0 4px 18px;
      margin: 22px 0; font-style: italic; max-width: 54ch; line-height: 1.5; color: hsl(var(--foreground));
    }
    .p { font-size: 16px; line-height: 1.55; margin-top: 14px; max-width: 56ch; color: hsl(var(--muted-foreground)); }
    .cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 26px; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: hsl(var(--foreground)); border: 1.5px solid hsl(var(--foreground));
      color: hsl(var(--background)); font-weight: 700; font-size: 14px; padding: 9px 17px;
      box-shadow: 2px 2px 0 hsl(var(--foreground)); text-decoration: none;
      transition: transform .05s, box-shadow .05s, background .1s;
    }
    .btn:hover { background: hsl(var(--foreground) / 0.85); }
    .btn:active { transform: translate(2px, 2px); box-shadow: 0 0 0; }
    .note { font-size: 13px; color: hsl(var(--muted-foreground)); }
    .note a { color: hsl(var(--foreground)); text-decoration: underline; text-underline-offset: 2px; }
    .idxh { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .12em; margin-bottom: 8px; }
    .dot {
      height: 6px; opacity: .5;
      background-image: radial-gradient(hsl(var(--foreground)) .5px, transparent .6px);
      background-size: 3px 3px;
    }
    .idx { border: 1.5px solid hsl(var(--foreground)); border-top: none; }
    .ix {
      display: flex; justify-content: space-between; align-items: baseline; gap: 12px;
      padding: 12px 13px; border-bottom: 1px solid hsl(var(--border));
      text-decoration: none; color: hsl(var(--foreground));
    }
    .ix:last-child { border-bottom: none; }
    .ix:hover { background: hsl(var(--muted)); }
    .ixl .k { font-weight: 700; }
    .ixl .d { font-weight: 400; color: hsl(var(--muted-foreground)); }
    .ixl .live {
      font-size: 7.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em;
      border: 1px solid currentColor; border-radius: 2px; padding: 1px 3px;
      vertical-align: middle; margin-left: 5px;
    }
    .v { font-family: "Courier New", monospace; font-size: 11.5px; color: hsl(var(--muted-foreground)); white-space: nowrap; }
    .recent .rlist { list-style: none; padding: 0; margin: 10px 0 0; }
    .recent li a {
      display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
      padding: 10px 0; border-bottom: 1px solid hsl(var(--border));
      text-decoration: none; color: hsl(var(--foreground));
    }
    .recent li a:hover .rt { text-decoration: underline; text-underline-offset: 2px; }
    .recent .rd { font-family: "Courier New", monospace; font-size: 12px; color: hsl(var(--muted-foreground)); white-space: nowrap; }
    .more { display: inline-block; margin-top: 14px; font-size: 13px; color: hsl(var(--muted-foreground)); text-decoration: underline; text-underline-offset: 2px; }
    .more:hover { color: hsl(var(--foreground)); }
    @media (max-width: 820px) {
      .grid { grid-template-columns: 1fr; gap: 30px; }
      .ds { padding: 16px 20px 40px; }
    }
  </style>
</BaseLayout>
