---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PostTitle from '@/components/PostTitle.astro'
import PortfolioBoard from '@/components/PortfolioBoard.astro'
import { getCollection } from 'astro:content'

const essays = (await getCollection('blog'))
  .filter(
    (p) =>
      !p.data.draft &&
      p.data.category.toLowerCase() !== 'interviews' &&
      p.data.category !== 'Links'
  )
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })

---

<BaseLayout
  title="Gökhan Turhan"
  description="Full-stack builder — one person, a fleet of agents. Agent-native venues, rails, and benchmarks live in production on x402: Ishtar, CURB, HeartBench. Journal, CV, publishing."
>
  <div class="ds">
    <div class="meta">Gökhan Turhan · full-stack builder · fintech × AI × agent-native markets</div>
    <div class="dither"></div>

    <div class="hero">
      <h1 class="h">Gökhan Turhan</h1>
      <p class="lead">
        I'm a <b>full-stack builder</b> — one person, a fleet of agents, everything
        shipped end to end. I design the product, write the code, wire the payments,
        run the security program, and operate what ships: Ishtar, a venue where agents
        court and humans meet; CURB, a rail where agents trade inference for USDC;
        HeartBench, HeartPrefs, and the pipes that meter the x402 economy. All of it is
        <b>live, in production, taking real machine payments</b>. Fintech is still the
        substrate — custody, tokenization, market structure — I've just stopped
        explaining it in decks and started clearing it in prod. I also make conceptual
        art; it keeps me honest about naming and compression.
      </p>
      <p class="p">
        What I want more of is <b>acceleration you can weigh</b>: gigawatts, foundries,
        compute, mass to orbit. Hard tech, deep tech, manufacturing, spaceflight —
        capacity, not adjectives; the base the big problems don't get solved without.
        Governance should compete for that base like any other vendor: jurisdictions
        running different rules, rewarded on outcomes, not paperwork theater. My corner
        of it is the market plumbing — software that buys, sells, and settles with
        other software, fast enough to keep up with the factories we still have to
        build.
      </p>
      <div class="cta">
        <a class="btn" href="/journal/">Read the journal →</a>
        <span class="note">contact:
          <a href="https://x.com/goekhan" target="_blank" rel="noopener">X</a> ·
          <a href="https://t.me/goekhanturhan" target="_blank" rel="noopener">Telegram</a> ·
          <a href="https://linkedin.com/in/goekhanturhan" target="_blank" rel="noopener">LinkedIn</a> ·
          <a href="mailto:contact@gokhan.vc">email</a>
        </span>
      </div>
    </div>

    <div class="dither dgap"></div>
    <PortfolioBoard />

    {essays.length > 0 && (
      <>
        <div class="dither dgap"></div>
        <section class="recent">
          <div class="idxh">Recent from the journal</div>
          <ul class="rlist">
            {essays.map((post) => (
              <li>
                <a href={`/journal/${post.slug}/`}>
                  <PostTitle title={post.data.title} class="rt" />
                  <span class="rd">{fmt(post.data.publishDate)}</span>
                </a>
              </li>
            ))}
          </ul>
          <a class="more" href="/journal/">All essays →</a>
        </section>
      </>
    )}
  </div>

  <style>
    .ds { padding: 24px 34px 48px; color: var(--ink); }
    .meta {
      font-family: var(--font-mono);
      font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
      color: var(--dim);
      text-align: left;
    }
    .dither {
      height: 0; margin: 14px 0;
      border-top: 1px solid var(--ink);
      background-image: none; opacity: 1;
    }
    .dgap { margin: 36px 0 22px; }
    .hero { max-width: 72ch; margin: 0; padding-top: 14px; }
    .h {
      font-size: clamp(26px, 5.5vw, 44px); font-weight: 700;
      letter-spacing: .02em; line-height: 1.05; text-align: left;
    }
    .lead { font-size: 14px; line-height: 1.55; margin-top: 22px; color: var(--ink); max-width: 72ch; }
    .lead b, .p b { font-weight: 700; }
    .p {
      font-size: 14px; line-height: 1.55; margin-top: 18px;
      color: var(--dim);
      border-left: 2px solid var(--ink); padding-left: 18px;
      max-width: 72ch;
    }
    .cta { display: flex; align-items: center; justify-content: flex-start; gap: 16px; flex-wrap: wrap; margin-top: 28px; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      background: transparent; border: 2px solid var(--ink);
      color: var(--ink); font-weight: 700; font-size: 12px;
      text-transform: uppercase; letter-spacing: .14em;
      padding: 9px 17px;
      text-decoration: none;
    }
    .btn:hover { background: var(--faint); }
    .note { font-size: 13px; color: var(--dim); }
    .note a { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }
    .idxh {
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .22em; margin-bottom: 8px; text-align: left;
      border-bottom: 2px solid var(--ink); padding-bottom: .35rem;
    }
    .recent { max-width: 72ch; margin: 0; }
    .recent .rlist { list-style: none; padding: 0; margin: 10px 0 0; }
    .recent li a {
      display: flex; justify-content: space-between; align-items: baseline; gap: 16px;
      padding: 10px 8px; margin: 0 -8px; border-bottom: 1px solid var(--ink);
      text-decoration: none; color: var(--ink);
    }
    .recent li a:hover { background: var(--faint); }
    .recent li a:hover .rt { text-decoration: underline; text-underline-offset: 2px; }
    .recent .rd { font-family: var(--font-mono); font-size: 12px; color: var(--dim); white-space: nowrap; }
    .more { display: inline-block; margin-top: 14px; font-size: 13px; color: var(--dim); text-decoration: underline; text-underline-offset: 2px; }
    .more:hover { color: var(--ink); }
    @media (max-width: 820px) {
      .ds { padding: 16px 20px 40px; }
      .hero { padding-top: 8px; }
    }
  </style>
</BaseLayout>
