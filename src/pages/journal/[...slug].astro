---
import { type CollectionEntry, getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SocialShare from '@/components/SocialShare.astro'
import PostTitle from '@/components/PostTitle.astro'
import ResponsiveImage from '@/components/ResponsiveImage.astro'
import SubscribeBlock from '@/components/SubscribeBlock.astro'
import { formatDate, humanizeKebab, plainPostTitle } from '@/lib/utils'

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((post) => !post.data.draft)
  // Stable, deterministic doc numbers: order all published posts by publishDate
  // (oldest first) and assign JOURNAL-<n> by position. Slug tiebreak keeps it
  // stable when two posts share a date.
  const ordered = [...posts].sort((a, b) => {
    const d = a.data.publishDate.getTime() - b.data.publishDate.getTime()
    return d !== 0 ? d : a.slug.localeCompare(b.slug)
  })
  const docNumber = new Map(ordered.map((p, i) => [p.slug, i + 1]))
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { ...post, docNumber: docNumber.get(post.slug) ?? 0 },
  }))
}

type Props = CollectionEntry<'blog'> & { docNumber: number }

const post = Astro.props
const { Content, headings } = await post.render()

// Doc-strip identifiers — plain mono labels in the datasheet register.
const docId = `JOURNAL-${String(post.docNumber).padStart(3, '0')}`
const docCategory = (post.data.category || 'JOURNAL').toUpperCase()
const docDate = post.data.publishDate.toISOString().slice(0, 10)

// Default Article schema - always present for SEO
const defaultArticleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": plainPostTitle(post.data.title),
  "description": post.data.description,
  "author": {
    "@type": "Person",
    "name": post.data.author,
    "url": "https://gokhanturhan.com"
  },
  "publisher": {
    "@type": "Person",
    "name": "Gökhan Turhan",
    "url": "https://gokhanturhan.com"
  },
  "datePublished": post.data.publishDate.toISOString(),
  "url": `https://gokhanturhan.com/journal/${post.slug}/`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://gokhanturhan.com/journal/${post.slug}/`
  },
  "image": post.data.heroImage ? `https://gokhanturhan.com${post.data.heroImage}` : "https://gokhanturhan.com/og-default.png",
  "articleSection": post.data.category,
  "keywords": post.data.tags?.join(', ') || ''
}

// Additional custom schema from frontmatter (if any)
const customSchemas = post.data.schema ? (Array.isArray(post.data.schema) ? post.data.schema : [post.data.schema]) : []

// CONTENTS box: numbered list of in-page section links (depth 2-3).
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3)
const showToc = tocHeadings.length >= 2
---

<BaseLayout
  title={plainPostTitle(post.data.title)}
  description={post.data.description}
  type="article"
  image={post.data.heroImage || `/og/${post.slug}.png`}
  canonicalURL={post.data.originalUrl}
  hideFooterSubscribe
>
  {/* Default Article Schema - always present */}
  <script is:inline type="application/ld+json" set:html={JSON.stringify(defaultArticleSchema)} slot="head" />

  {/* Additional custom schemas from frontmatter */}
  {customSchemas.map((schema: any) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      ...schema
    })} slot="head" />
  ))}

  {/* Additional meta keywords for LLM discoverability */}
  {post.data.seoKeywords && (
    <meta name="keywords" content={post.data.seoKeywords.join(', ')} slot="head" />
  )}

  <div class="dispatch mx-auto max-w-2xl px-6 py-8 lg:py-12">
    <article>
      <!-- (a) DOC-STRIP -->
      <div class="docstrip">
        <span class="docstrip-id"><span class="tick" aria-hidden="true">▮</span>&nbsp;DOC · {docId} · {docCategory}</span>
        <span class="docstrip-pub">PUBLISHED · {docDate}</span>
      </div>

      <!-- Article Header -->
      <header class="dispatch-header">
        {post.data.heroImage && (
          <ResponsiveImage
            src={post.data.heroImage}
            alt={post.data.heroImageAlt || plainPostTitle(post.data.title)}
            class="w-full mb-8"
            loading="eager"
            fetchpriority="high"
          />
        )}

        <!-- (b) mono uppercase eyebrow -->
        <div class="eyebrow">JOURNAL · {docDate} · GÖKHAN TURHAN</div>

        <!-- (c) big bold H1 -->
        <PostTitle title={post.data.title} as="h1" class="dispatch-title" />

        {post.slug === 'not-raising-a-preseed' && (
          <p class="deck-links">
            <a class="deck-pdf" href="https://ishtar.numetal.xyz/deck/not-raising-a-preseed/ishtar-deck-not-a-preseed.pdf" download>Download PDF</a>
            <a class="deck-view" href="https://ishtar.numetal.xyz/deck/not-raising-a-preseed/">View deck →</a>
            <a class="deck-md" href="https://ishtar.numetal.xyz/deck/not-raising-a-preseed/deck.md">deck.md</a>
          </p>
        )}

        {post.data.description && (
          <p class="dispatch-lede">{post.data.description}</p>
        )}

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="dispatch-tags">
            {post.data.tags.map(tag => (
              <a
                href={`/archive/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                class="dispatch-tag"
              >
                {humanizeKebab(tag)}
              </a>
            ))}
          </div>
        )}
      </header>

      {/* (d) bordered CONTENTS box — replaces the sidebar TOC */}
      {showToc && (
        <details class="contents-box" open>
          <summary class="contents-label">Contents</summary>
          <ol class="contents-list">
            {tocHeadings.map((heading) => (
              <li class={heading.depth === 3 ? 'contents-item contents-item-nested' : 'contents-item'}>
                <a href={`#${heading.slug}`} class="contents-link">{heading.text}</a>
              </li>
            ))}
          </ol>
        </details>
      )}

      <!-- Article Content -->
      <div class="dispatch-prose prose prose-lg prose-neutral dark:prose-invert max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-foreground prose-a:underline prose-a:decoration-1 prose-a:underline-offset-2 hover:prose-a:decoration-2 prose-p:text-foreground/90 prose-li:text-foreground/90 prose-blockquote:border-l-2 prose-blockquote:border-muted-foreground/30 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:text-muted-foreground prose-code:text-sm prose-code:bg-muted/50 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none prose-pre:bg-muted/30 prose-pre:border prose-pre:border-border">
        <Content />
      </div>

      <!-- Social Share -->
      <div class="mt-12 pt-8 border-t border-border">
        <SocialShare
          title={plainPostTitle(post.data.title)}
          url={`${Astro.site?.origin || 'https://gokhanturhan.com'}${Astro.url.pathname}`}
          description={post.data.description}
        />
      </div>

      <!-- Article Footer -->
      <footer class="mt-8 pt-8 border-t border-border">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 text-sm text-muted-foreground">
          <span>
            Published on {formatDate(post.data.publishDate)}
          </span>
          <div class="flex items-center gap-6">
            <a
              href="/journal"
              class="hover:text-foreground transition-colors"
            >
              ← All posts
            </a>
            <a
              href="/rss.xml"
              class="hover:text-foreground transition-colors"
            >
              RSS
            </a>
          </div>
        </div>
      </footer>
    </article>
  </div>
  <SubscribeBlock />
</BaseLayout>

<style>
  /* Dispatch layout — datasheet register, strictly monochrome. Hierarchy is
     carried by weight, case, value, and rules; never hue. Mono = house Courier
     stack (matches globals.css / index.astro); body = Helvetica via BaseLayout. */

  /* (a) DOC-STRIP */
  .docstrip {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid hsl(var(--border));
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }
  .docstrip-id { color: hsl(var(--foreground)); }
  .docstrip .tick { color: hsl(var(--foreground)); }
  .docstrip-pub { color: hsl(var(--muted-foreground)); }

  /* Header */
  .dispatch-header {
    margin: 1.8rem 0 0;
  }

  /* (b) mono uppercase eyebrow */
  .eyebrow {
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin-bottom: 0.55rem;
  }

  /* (c) big bold H1 title — numetal type-scale, translated to black */
  .dispatch-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: hsl(var(--foreground));
    margin: 0 0 0.6rem;
  }

  .dispatch-lede {
    font-size: 16px;
    line-height: 1.6;
    color: hsl(var(--muted-foreground));
    margin: 0.6rem 0 0;
    max-width: 62ch;
  }

  .deck-links {
    margin: 1.1rem 0 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem 0.75rem;
  }
  .deck-pdf {
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: hsl(var(--foreground));
    border: 2px solid hsl(var(--foreground));
    padding: 0.45rem 0.85rem;
    background: hsl(var(--card));
    font-weight: 700;
  }
  .deck-view {
    color: hsl(var(--foreground));
    border-bottom: 1px solid hsl(var(--border));
    font-family: "Courier New", Courier, ui-monospace, monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 11px;
    text-decoration: none;
  }
  .deck-md {
    color: hsl(var(--muted-foreground));
    border-bottom: 1px solid hsl(var(--border));
    font-size: 13px;
    text-decoration: none;
  }

  .dispatch-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.9rem;
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .dispatch-tag {
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    border-bottom: 1px solid hsl(var(--border));
  }
  .dispatch-tag:hover { color: hsl(var(--foreground)); border-color: hsl(var(--foreground)); }

  /* (d) bordered CONTENTS box */
  .contents-box {
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    margin: 1.9rem 0 0;
    padding: 0;
  }
  .contents-label {
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid hsl(var(--border));
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .contents-label::-webkit-details-marker { display: none; }
  .contents-label::before { content: "▸  "; color: hsl(var(--foreground)); }
  .contents-box[open] > .contents-label::before { content: "▾  "; }
  .contents-box:not([open]) > .contents-label { border-bottom: none; }
  .contents-list {
    list-style: none;
    counter-reset: contents;
    margin: 0;
    padding: 0.7rem 0.9rem 0.85rem;
    font-size: 0.9rem;
  }
  .contents-item {
    counter-increment: contents;
    line-height: 1.5;
    margin: 0.28rem 0;
    display: flex;
    gap: 0.55rem;
  }
  .contents-item::before {
    content: counter(contents, decimal-leading-zero);
    font-family: "Courier New", Courier, ui-monospace, monospace;
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    flex: 0 0 auto;
    padding-top: 0.12em;
  }
  .contents-item-nested {
    padding-left: 1.4rem;
    counter-increment: none;
  }
  .contents-item-nested::before {
    content: "–";
    color: hsl(var(--muted-foreground));
  }
  .contents-link {
    color: hsl(var(--foreground));
    text-decoration: none;
    border-bottom: 1px solid hsl(var(--border));
  }
  .contents-link:hover {
    border-color: hsl(var(--foreground));
  }

  /* Prose spacing + anchors */
  .dispatch-prose {
    margin-top: 2rem;
  }

  /* SS1 TL;DR box — bordered, offset shadow, mono label. Monochrome house style. */
  .dispatch-prose :global(.tldr) {
    border: 1.5px solid hsl(var(--foreground));
    background: hsl(var(--card));
    padding: 14px 18px;
    margin: 0 0 26px;
    box-shadow: 5px 5px 0 hsl(var(--foreground));
  }
  .dispatch-prose :global(.tldr .tldr-k) {
    display: block;
    font-family: "Courier New", ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin-bottom: 8px;
  }
  .dispatch-prose :global(.tldr ul) { margin: 0; padding-left: 18px; }
  .dispatch-prose :global(.tldr li) { margin: 6px 0; font-size: 15px; line-height: 1.5; }
  .dispatch-prose :global(h1),
  .dispatch-prose :global(h2),
  .dispatch-prose :global(h3),
  .dispatch-prose :global(h4),
  .dispatch-prose :global(h5),
  .dispatch-prose :global(h6) {
    scroll-margin-top: 5rem;
  }

  /* Body paragraphs — numetal type-scale (16px / 1.62), translated to black.
     Overrides the Tailwind `prose-lg` sizes so the rendered article matches. */
  .dispatch-prose :global(:where(p)) {
    font-size: 16px;
    line-height: 1.62;
    margin: 0 0 18px;
    color: hsl(var(--foreground));
  }
  .dispatch-prose :global(:where(li)) {
    font-size: 16px;
    line-height: 1.62;
    color: hsl(var(--foreground));
  }

  /* (e) section h2 headings — top border-rule + numetal 21px scale */
  .dispatch-prose :global(h2) {
    font-size: 21px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 34px 0 12px;
    padding-top: 14px;
    border-top: 1px solid hsl(var(--border));
    color: hsl(var(--foreground));
  }
  .dispatch-prose :global(h2:first-child) {
    margin-top: 1rem;
    padding-top: 0;
    border-top: 0;
  }

  /* (f) sub-head h3 — numetal mono uppercase label */
  .dispatch-prose :global(h3) {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-family: "Courier New", ui-monospace, monospace;
    color: hsl(var(--foreground));
    margin: 26px 0 8px;
  }

  .dispatch-prose :global(p + p) {
    margin-top: 0;
  }

  /* Anchor link styles */
  .dispatch-prose :global(h1 a.anchor-link),
  .dispatch-prose :global(h2 a.anchor-link),
  .dispatch-prose :global(h3 a.anchor-link),
  .dispatch-prose :global(h4 a.anchor-link),
  .dispatch-prose :global(h5 a.anchor-link),
  .dispatch-prose :global(h6 a.anchor-link) {
    text-decoration: none !important;
    color: inherit;
  }

  .dispatch-prose :global(.superseded-content) {
    opacity: 0.7;
  }

  .dispatch-prose :global(.superseded-content :where(p, li, h2, h3, h4, h5, h6, a, strong, em, blockquote, td, th, figcaption)) {
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--muted-foreground) 50%, transparent);
  }

  /* Responsive: tighter padding on mobile + numetal small-screen scale */
  @media (max-width: 640px) {
    .docstrip { font-size: 10px; letter-spacing: 0.08em; }
    .contents-list { padding: 0.6rem 0.7rem 0.7rem; }
    .contents-label { padding: 0.55rem 0.7rem; }
    .dispatch-title { font-size: 26px; }
    .dispatch-prose :global(:where(p)),
    .dispatch-prose :global(:where(li)) { font-size: 15px; margin-bottom: 15px; }
  }
</style>
