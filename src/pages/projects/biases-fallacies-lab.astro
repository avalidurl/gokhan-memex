---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { studyDeck, studyDeckStats, studySourceStack } from '@/data/bias-fallacy-deck'

const deckJson = JSON.stringify(studyDeck)
---

<BaseLayout
  title="Biases & Fallacies Lab"
  description={`A text-based training game for ${studyDeckStats.biases} cognitive biases and ${studyDeckStats.fallacies} logical fallacies.`}
  showBreadcrumbs={false}
>
  <div class="mx-auto max-w-7xl px-6 py-10 lg:py-14">
    <header class="mb-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(260px,320px)] lg:items-end">
      <div class="max-w-3xl">
        <p class="raw-kicker mb-4">Interactive Project</p>
        <h1 class="mb-4 text-4xl font-semibold tracking-tight text-foreground">Biases & Fallacies Lab</h1>
        <p class="text-lg text-muted-foreground">
          A recognition drill for messy real-world reasoning. Read one case, name the pattern, and use the atlas only when you need the reference layer.
        </p>
      </div>
      <div class="space-y-4 border-l border-border/70 pl-5">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Protocol</p>
          <p class="mt-2 text-sm leading-6 text-muted-foreground">
            Answer with <code>a</code> through <code>d</code>. Use <code>h</code> for hint and <code>n</code> for next. Search the atlas when you want the reference file.
          </p>
        </div>
        <p class="m-0 text-sm leading-6 text-muted-foreground">
          Source note: this lab uses a cross-sourced working taxonomy from {studySourceStack.length} reference layers rather than pretending one website is definitive.
        </p>
      </div>
    </header>

    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.55fr)_minmax(320px,0.92fr)]">
      <section class="overflow-hidden rounded-[2rem] border border-border/70 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(248,250,252,0.92))] text-foreground shadow-sm">
        <div class="border-b border-border/70 px-6 py-6 lg:px-8">
          <div class="flex flex-col gap-6">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="max-w-2xl">
                <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.28em] text-muted-foreground">Play Surface</p>
                <h2 class="m-0 text-2xl font-semibold text-foreground">Field drill</h2>
                <p class="mt-2 text-sm leading-6 text-muted-foreground">
                  One case at a time. Keep the rhythm tight, keep the mistakes cheap, and let the explanations teach the pattern.
                </p>
              </div>
              <div class="flex flex-wrap gap-2" id="mode-buttons">
                <button
                  type="button"
                  data-mode="mixed"
                  class="mode-button rounded-full border border-border bg-background px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Mixed
                </button>
                <button
                  type="button"
                  data-mode="bias"
                  class="mode-button rounded-full border border-border bg-background px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Bias
                </button>
                <button
                  type="button"
                  data-mode="fallacy"
                  class="mode-button rounded-full border border-border bg-background px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Fallacy
                </button>
              </div>
            </div>

            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
              <div>
                <p class="mb-1 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Mode</p>
                <p class="m-0 text-lg font-semibold text-foreground" id="stat-mode">Mixed deck</p>
              </div>
              <div>
                <p class="mb-1 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Round</p>
                <p class="m-0 text-lg font-semibold text-foreground" id="stat-round">0</p>
              </div>
              <div>
                <p class="mb-1 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Streak</p>
                <p class="m-0 text-lg font-semibold text-foreground" id="stat-streak">0</p>
              </div>
              <div>
                <p class="mb-1 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Score</p>
                <p class="m-0 text-lg font-semibold text-foreground" id="stat-score">0</p>
              </div>
            </div>

            <div class="space-y-3">
              <div class="flex flex-wrap items-center justify-between gap-3 text-sm text-muted-foreground">
                <span>Mastery coverage <span class="font-medium text-foreground" id="stat-mastered">0/0</span></span>
                <span>Accuracy <span class="font-medium text-foreground" id="stat-accuracy">0%</span></span>
              </div>
              <div class="h-2 rounded-full bg-black/6 dark:bg-white/10">
                <div id="mastery-bar" class="h-full w-0 rounded-full bg-amber-300 transition-[width] duration-300 ease-out"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="px-6 py-6 lg:px-8 lg:py-8">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_300px]">
            <div class="min-w-0">
              <p id="current-meta" class="mb-4 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">
                Waiting for case data.
              </p>
              <p id="current-scenario" class="m-0 max-w-3xl text-2xl font-medium leading-10 text-foreground sm:text-[2rem] sm:leading-[2.8rem]">
                Waiting for case data.
              </p>
              <p id="current-family" class="mt-4 max-w-2xl text-sm leading-6 text-muted-foreground">
                Choose the pattern that best explains the case.
              </p>
              <div id="feedback-card" class="mt-6 hidden"></div>
            </div>

            <aside class="min-w-0 border-t border-border/70 pt-6 lg:border-l lg:border-t-0 lg:pl-6 lg:pt-0">
              <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Choose the match</p>
              <div id="answer-buttons" class="grid gap-3"></div>
              <button
                type="button"
                id="continue-button"
                class="mt-4 hidden w-full rounded-2xl bg-amber-300 px-4 py-3 text-sm font-semibold text-stone-950 transition hover:bg-amber-200"
              >
                Continue
              </button>

              <div class="mt-5 flex flex-wrap gap-2">
                <button
                  type="button"
                  data-command="hint"
                  class="quick-command rounded-full border border-border px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Hint
                </button>
                <button
                  type="button"
                  data-command="skip"
                  class="quick-command rounded-full border border-border px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Skip
                </button>
                <button
                  type="button"
                  data-command="explain"
                  class="quick-command rounded-full border border-border px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Explain
                </button>
                <button
                  type="button"
                  data-command="stats"
                  class="quick-command rounded-full border border-border px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Stats
                </button>
              </div>
              <p class="mt-4 text-xs leading-5 text-muted-foreground">
                Keyboard shortcuts: <code>a-d</code> answer, <code>h</code> hint, <code>n</code> next.
              </p>
            </aside>
          </div>
        </div>

        <div class="border-t border-border/70 px-6 py-5 lg:px-8">
          <details class="group">
            <summary class="cursor-pointer list-none font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">
              Power commands
            </summary>
            <form id="command-form" class="mt-4 space-y-3">
              <label class="sr-only" for="command-input">Command line</label>
              <div class="flex flex-col gap-3 sm:flex-row">
                <div class="flex min-w-0 flex-1 items-center rounded-2xl border border-border bg-background px-4">
                  <span class="mr-3 font-mono text-sm text-muted-foreground">$</span>
                  <input
                    id="command-input"
                    class="h-12 w-full bg-transparent font-mono text-sm text-foreground outline-none placeholder:text-muted-foreground"
                    type="text"
                    placeholder="Type a, b, c, d, hint, next, bias, fallacy, mixed, stats"
                    autocomplete="off"
                    spellcheck="false"
                  />
                </div>
                <button
                  type="submit"
                  class="rounded-2xl border border-border bg-background px-5 py-3 font-mono text-xs uppercase tracking-[0.2em] text-foreground transition hover:border-foreground/20 hover:bg-muted/40"
                >
                  Run
                </button>
              </div>
            </form>
          </details>
        </div>
      </section>

      <aside class="min-w-0 space-y-6">
        <section class="overflow-hidden rounded-[2rem] border border-border/70 bg-background shadow-sm">
          <div class="border-b border-border/70 px-6 py-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Reference Surface</p>
                <h2 class="m-0 text-xl font-semibold text-foreground">Case notes & atlas</h2>
              </div>
              <div class="flex flex-wrap gap-2">
                <button
                  type="button"
                  data-inspector-view="card"
                  class="inspector-button rounded-full border border-border bg-background px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Case notes
                </button>
                <button
                  type="button"
                  data-inspector-view="library"
                  class="inspector-button rounded-full border border-border bg-background px-4 py-2 font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
                >
                  Atlas
                </button>
              </div>
            </div>
          </div>

          <div id="card-panel" class="px-6 py-6">
            <div id="focus-card" class="space-y-4 text-sm text-muted-foreground">
              <p class="m-0">Answer a case or open the atlas to pin a concept here.</p>
            </div>
          </div>

          <div id="library-panel" class="hidden border-t border-border/70 px-6 py-6">
            <label class="mb-2 block text-sm font-medium text-foreground" for="atlas-search">Search the atlas</label>
            <input
              id="atlas-search"
              class="w-full rounded-2xl border border-border bg-background px-4 py-3 text-sm text-foreground outline-none transition focus:border-foreground/20"
              type="search"
              placeholder="Search by name, family, or concept"
              autocomplete="off"
              spellcheck="false"
            />
            <div class="mt-4 flex flex-wrap gap-2 text-xs text-muted-foreground">
              <span class="rounded-full border border-border px-3 py-1">{studyDeckStats.biases} biases</span>
              <span class="rounded-full border border-border px-3 py-1">{studyDeckStats.fallacies} fallacies</span>
              <span class="rounded-full border border-border px-3 py-1">{studyDeckStats.total} total cards</span>
            </div>
            <div id="atlas-list" class="mt-4 max-h-[32rem] space-y-2 overflow-y-auto pr-1"></div>
          </div>
        </section>

        <section class="rounded-[2rem] border border-border/70 bg-[linear-gradient(180deg,rgba(255,251,235,0.6),rgba(255,255,255,0.92))] px-6 py-6 shadow-sm dark:bg-[linear-gradient(180deg,rgba(41,37,36,0.9),rgba(12,10,9,0.98))]">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Session journal</p>
              <p class="m-0 text-sm leading-6 text-muted-foreground">
                The terminal flavor stays here: a compact trace of commands, hints, and outcomes.
              </p>
            </div>
            <button
              type="button"
              data-command="help"
              class="quick-command rounded-full border border-border bg-background px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground transition hover:border-foreground/20 hover:text-foreground"
            >
              Help
            </button>
          </div>
          <div id="terminal-log" class="mt-5 space-y-2" aria-live="polite"></div>
        </section>

        <section class="rounded-[2rem] border border-border/70 bg-background px-6 py-6 shadow-sm">
          <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">Source stack</p>
          <ul class="m-0 space-y-2 pl-5 text-sm leading-6 text-muted-foreground">
            {studySourceStack.map((source) => (
              <li>
                <a href={source.url} target="_blank" rel="noopener">{source.label}</a> {source.description}
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </div>

  <script is:inline id="study-deck-data" type="application/json" set:html={deckJson}></script>

  <script>
    type SourceRef = {
      slug: string
      label: string
      url: string
      kind: string
      description: string
    }

    type StudyCard = {
      id: string
      name: string
      kind: 'bias' | 'fallacy'
      family: string
      scenario: string
      summary: string
      whyItFits: string
      counter: string
      aliases?: string[]
      sources: SourceRef[]
    }

    type Mode = 'mixed' | 'bias' | 'fallacy'
    type InspectorView = 'card' | 'library'

    type LogLine = {
      speaker: 'system' | 'player'
      tone?: 'neutral' | 'success' | 'warning' | 'accent'
      text: string
    }

    type CardProgress = {
      seen: number
      correct: number
      wrong: number
    }

    type StoredProgress = {
      cards: Record<string, CardProgress>
      bestStreak: number
    }

    declare global {
      interface Window {
        render_game_to_text?: () => string
        advanceTime?: (ms: number) => void
        __biasFallacyLab?: BiasFallacyLab
      }
    }

    const LETTERS = ['A', 'B', 'C', 'D'] as const
    const STORAGE_KEY = 'bias-fallacy-lab-progress-v1'

    class BiasFallacyLab {
      deck: StudyCard[]
      logs: LogLine[] = []
      progress: StoredProgress = { cards: {}, bestStreak: 0 }
      mode: Mode = 'mixed'
      inspectorView: InspectorView = 'card'
      round = 0
      score = 0
      streak = 0
      currentCard: StudyCard | null = null
      currentOptions: StudyCard[] = []
      solved = false
      hintUsed = false
      selectedOptionId: string | null = null
      lastOutcome: 'correct' | 'incorrect' | 'skipped' | null = null
      focusCard: StudyCard | null = null
      atlasSearch = ''
      virtualMs = 0

      terminalLog = document.getElementById('terminal-log')
      feedbackCard = document.getElementById('feedback-card')
      answerButtons = document.getElementById('answer-buttons')
      continueButton = document.getElementById('continue-button') as HTMLButtonElement | null
      commandForm = document.getElementById('command-form') as HTMLFormElement | null
      commandInput = document.getElementById('command-input') as HTMLInputElement | null
      atlasSearchInput = document.getElementById('atlas-search') as HTMLInputElement | null
      atlasList = document.getElementById('atlas-list')
      focusCardEl = document.getElementById('focus-card')
      currentScenario = document.getElementById('current-scenario')
      currentMeta = document.getElementById('current-meta')
      currentFamily = document.getElementById('current-family')
      modeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.mode-button'))
      inspectorButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.inspector-button'))
      quickCommandButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.quick-command'))
      cardPanel = document.getElementById('card-panel')
      libraryPanel = document.getElementById('library-panel')

      statMode = document.getElementById('stat-mode')
      statRound = document.getElementById('stat-round')
      statScore = document.getElementById('stat-score')
      statStreak = document.getElementById('stat-streak')
      statAccuracy = document.getElementById('stat-accuracy')
      statMastered = document.getElementById('stat-mastered')
      masteryBar = document.getElementById('mastery-bar')

      constructor(deck: StudyCard[]) {
        this.deck = deck
        this.loadProgress()
        this.bindEvents()
        this.boot()
      }

      boot() {
        this.logSystem('Biases & Fallacies Lab online.')
        this.logSystem(`Loaded ${this.deck.length} cards. Type help for commands or answer with A-D.`)
        this.logSystem('Modes: mixed, bias, fallacy. Progress is stored locally for targeted drills.')
        this.startRound(true)
      }

      bindEvents() {
        this.commandForm?.addEventListener('submit', (event) => {
          event.preventDefault()
          const value = this.commandInput?.value ?? ''
          this.commandInput!.value = ''
          this.handleCommand(value)
        })

        this.continueButton?.addEventListener('click', () => {
          this.handleCommand('next')
        })

        this.modeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const mode = button.dataset.mode as Mode
            this.handleCommand(mode)
          })
        })

        this.inspectorButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const view = button.dataset.inspectorView as InspectorView
            this.setInspectorView(view)
          })
        })

        this.quickCommandButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const command = button.dataset.command
            if (command) this.handleCommand(command)
          })
        })

        this.atlasSearchInput?.addEventListener('input', (event) => {
          this.inspectorView = 'library'
          this.atlasSearch = (event.target as HTMLInputElement).value.trim()
          this.renderAtlas()
          this.renderInspector()
          this.syncTextState()
        })

        document.addEventListener('keydown', (event) => {
          const active = document.activeElement
          const isTyping =
            active instanceof HTMLInputElement ||
            active instanceof HTMLTextAreaElement ||
            active instanceof HTMLSelectElement

          if (isTyping) return

          const key = event.key.toLowerCase()
          if (['a', 'b', 'c', 'd'].includes(key)) {
            event.preventDefault()
            this.handleCommand(key)
          }
          if (key === 'n') {
            event.preventDefault()
            this.handleCommand('next')
          }
          if (key === 'h') {
            event.preventDefault()
            this.handleCommand('hint')
          }
        })
      }

      loadProgress() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY)
          if (!raw) return
          const parsed = JSON.parse(raw) as StoredProgress
          if (parsed && parsed.cards) {
            this.progress = parsed
          }
        } catch (error) {
          console.error('Failed to load bias lab progress', error)
        }
      }

      saveProgress() {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(this.progress))
        } catch (error) {
          console.error('Failed to save bias lab progress', error)
        }
      }

      filteredDeck(mode = this.mode) {
        return this.deck.filter((card) => mode === 'mixed' || card.kind === mode)
      }

      mastery(card: StudyCard) {
        return this.progress.cards[card.id] ?? { seen: 0, correct: 0, wrong: 0 }
      }

      masteryPriority(card: StudyCard) {
        const record = this.mastery(card)
        if (record.seen === 0) return 100
        return (record.wrong + 1) * 6 + Math.max(0, record.seen - record.correct) * 3 - record.correct * 1.5
      }

      masteredCount() {
        return this.deck.filter((card) => {
          const record = this.mastery(card)
          return record.seen >= 2 && record.correct / record.seen >= 0.7
        }).length
      }

      totalAttempts() {
        return Object.values(this.progress.cards).reduce((sum, record) => sum + record.seen, 0)
      }

      totalCorrect() {
        return Object.values(this.progress.cards).reduce((sum, record) => sum + record.correct, 0)
      }

      overallAccuracy() {
        const attempts = this.totalAttempts()
        if (attempts === 0) return 0
        return Math.round((this.totalCorrect() / attempts) * 100)
      }

      masteryPercent() {
        if (this.deck.length === 0) return 0
        return Math.round((this.masteredCount() / this.deck.length) * 100)
      }

      randomPick<T>(items: T[]) {
        return items[Math.floor(Math.random() * items.length)]
      }

      shuffle<T>(items: T[]) {
        const clone = [...items]
        for (let index = clone.length - 1; index > 0; index -= 1) {
          const swapIndex = Math.floor(Math.random() * (index + 1))
          ;[clone[index], clone[swapIndex]] = [clone[swapIndex], clone[index]]
        }
        return clone
      }

      pickCard() {
        const candidates = this.filteredDeck()
        const ranked = [...candidates].sort((a, b) => this.masteryPriority(b) - this.masteryPriority(a))
        const shortlist = ranked.slice(0, Math.min(12, ranked.length))
        return this.randomPick(shortlist)
      }

      buildOptions(card: StudyCard) {
        const sameKind = this.deck.filter((candidate) => candidate.kind === card.kind && candidate.id !== card.id)
        const sameFamily = sameKind.filter((candidate) => candidate.family === card.family)
        const otherFamily = sameKind.filter((candidate) => candidate.family !== card.family)
        const picked: StudyCard[] = []

        const takeFrom = (pool: StudyCard[], count: number) => {
          for (const candidate of this.shuffle(pool)) {
            if (picked.length >= count) break
            if (!picked.some((item) => item.id === candidate.id)) {
              picked.push(candidate)
            }
          }
        }

        takeFrom(sameFamily, 1)
        takeFrom(otherFamily, 3)

        if (picked.length < 3) {
          takeFrom(sameKind, 3)
        }

        return this.shuffle([card, ...picked.slice(0, 3)])
      }

      startRound(initial = false) {
        this.round += 1
        this.solved = false
        this.hintUsed = false
        this.selectedOptionId = null
        this.lastOutcome = null
        this.currentCard = this.pickCard()
        this.currentOptions = this.buildOptions(this.currentCard)
        this.focusCard = this.currentCard
        this.inspectorView = 'card'

        if (!initial) {
          this.logSystem(`Spinning up round ${this.round} in ${this.modeLabel(this.mode)} mode.`)
        }

        this.logSystem(`Case file ${String(this.round).padStart(2, '0')} | ${this.modeLabel(this.mode)} | ${this.currentCard.kind.toUpperCase()} | ${this.currentCard.family}`)
        this.logSystem(this.currentCard.scenario, 'accent')
        this.logSystem(this.optionText())

        this.render()
      }

      optionText() {
        return this.currentOptions
          .map((option, index) => `${LETTERS[index]}. ${option.name}`)
          .join(' | ')
      }

      modeLabel(mode: Mode) {
        if (mode === 'bias') return 'Bias deck'
        if (mode === 'fallacy') return 'Fallacy deck'
        return 'Mixed deck'
      }

      answerWith(input: string) {
        if (!this.currentCard || this.solved) return

        const normalized = input.trim().toLowerCase()
        const byLetterIndex = LETTERS.findIndex((letter) => letter.toLowerCase() === normalized)
        let selected: StudyCard | undefined

        if (byLetterIndex >= 0) {
          selected = this.currentOptions[byLetterIndex]
        } else {
          selected = this.currentOptions.find((option) => {
            const aliases = option.aliases ?? []
            return [option.name, ...aliases].some((name) => this.normalize(name) === this.normalize(input))
          })
        }

        if (!selected) {
          this.logSystem(`Unknown answer "${input}". Use A-D or type one of the option names.`, 'warning')
          this.render()
          return
        }

        const record = this.progress.cards[this.currentCard.id] ?? { seen: 0, correct: 0, wrong: 0 }
        record.seen += 1
        this.selectedOptionId = selected.id

        const isCorrect = selected.id === this.currentCard.id
        if (isCorrect) {
          record.correct += 1
          this.score += this.hintUsed ? 7 : 10
          this.streak += 1
          this.progress.bestStreak = Math.max(this.progress.bestStreak, this.streak)
          this.lastOutcome = 'correct'
          this.logSystem(`Correct: ${this.currentCard.name}. ${this.currentCard.whyItFits}`, 'success')
        } else {
          record.wrong += 1
          this.streak = 0
          this.lastOutcome = 'incorrect'
          this.logSystem(`Missed. The right answer was ${this.currentCard.name}. ${this.currentCard.whyItFits}`, 'warning')
        }

        this.progress.cards[this.currentCard.id] = record
        this.focusCard = this.currentCard
        this.inspectorView = 'card'
        this.solved = true
        this.saveProgress()
        this.render()
      }

      explainCurrent() {
        if (!this.focusCard) return
        this.logSystem(`${this.focusCard.name}: ${this.focusCard.summary} Counter: ${this.focusCard.counter}`)
        this.render()
      }

      hint() {
        if (!this.currentCard || this.solved) return
        this.hintUsed = true
        this.logSystem(`Hint: focus on the ${this.currentCard.kind} family "${this.currentCard.family}" and ask what kind of reasoning broke.`, 'accent')
        this.render()
      }

      skip() {
        if (!this.currentCard || this.solved) {
          this.handleCommand('next')
          return
        }

        const record = this.progress.cards[this.currentCard.id] ?? { seen: 0, correct: 0, wrong: 0 }
        record.seen += 1
        record.wrong += 1
        this.progress.cards[this.currentCard.id] = record
        this.streak = 0
        this.focusCard = this.currentCard
        this.selectedOptionId = null
        this.lastOutcome = 'skipped'
        this.inspectorView = 'card'
        this.solved = true
        this.logSystem(`Skipped. ${this.currentCard.name}: ${this.currentCard.summary}`, 'warning')
        this.saveProgress()
        this.render()
      }

      setMode(mode: Mode) {
        this.mode = mode
        this.logSystem(`Switched to ${this.modeLabel(mode)}.`)
        this.startRound()
      }

      setInspectorView(view: InspectorView) {
        this.inspectorView = view
        this.renderInspector()
        this.syncTextState()
      }

      printStats() {
        const mastered = this.masteredCount()
        const seen = this.totalAttempts()
        this.logSystem(`Stats | score ${this.score} | streak ${this.streak} | best ${this.progress.bestStreak} | mastered ${mastered}/${this.deck.length} | attempts ${seen}`)
        this.render()
      }

      help() {
        this.logSystem('Commands: a-d, hint, explain, next, skip, stats, bias, fallacy, mixed, help')
        this.render()
      }

      handleCommand(raw: string) {
        const command = raw.trim()
        if (!command) return

        this.logPlayer(command)

        const normalized = command.toLowerCase()
        if (['a', 'b', 'c', 'd'].includes(normalized)) {
          this.answerWith(normalized)
          return
        }

        switch (normalized) {
          case 'help':
            this.help()
            return
          case 'hint':
            this.hint()
            return
          case 'explain':
            this.explainCurrent()
            return
          case 'next':
            this.startRound()
            return
          case 'skip':
            this.skip()
            return
          case 'stats':
            this.printStats()
            return
          case 'bias':
          case 'fallacy':
          case 'mixed':
            this.setMode(normalized as Mode)
            return
          default:
            this.answerWith(command)
        }
      }

      normalize(value: string) {
        return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim()
      }

      logSystem(text: string, tone: LogLine['tone'] = 'neutral') {
        this.logs.push({ speaker: 'system', tone, text })
        this.logs = this.logs.slice(-6)
      }

      logPlayer(text: string) {
        this.logs.push({ speaker: 'player', text })
        this.logs = this.logs.slice(-6)
      }

      escapeHtml(text: string) {
        return text
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;')
      }

      escapeAttribute(text: string) {
        return this.escapeHtml(text).replace(/`/g, '&#96;')
      }

      renderLog() {
        if (!this.terminalLog) return
        this.terminalLog.innerHTML = this.logs
          .map((line) => {
            const toneClass =
              line.speaker === 'player'
                ? 'text-foreground'
                : line.tone === 'success'
                  ? 'text-emerald-700 dark:text-emerald-300'
                  : line.tone === 'warning'
                    ? 'text-rose-700 dark:text-rose-300'
                    : line.tone === 'accent'
                      ? 'text-sky-700 dark:text-sky-300'
                      : 'text-foreground'

            const prefix = line.speaker === 'player' ? '&gt;' : '::'
            return `<div class="rounded-2xl border border-border/60 bg-background/80 px-3 py-2 font-mono text-xs leading-6 ${toneClass}"><span class="mr-2 text-muted-foreground">${prefix}</span>${this.escapeHtml(line.text)}</div>`
          })
          .join('')
      }

      renderButtons() {
        if (!this.answerButtons || !this.currentCard) return
        this.answerButtons.innerHTML = this.currentOptions
          .map((option, index) => {
            const label = LETTERS[index]
            const isCorrect = option.id === this.currentCard?.id
            const isSelected = option.id === this.selectedOptionId
            const solvedStateClasses = !this.solved
              ? 'border-border bg-background hover:border-foreground/20 hover:bg-black/[0.02] dark:hover:bg-white/[0.03]'
              : isCorrect
                ? 'border-emerald-300 bg-emerald-50/90 text-emerald-950 dark:border-emerald-700 dark:bg-emerald-950/30 dark:text-emerald-100'
                : isSelected
                  ? 'border-rose-300 bg-rose-50/90 text-rose-950 dark:border-rose-700 dark:bg-rose-950/30 dark:text-rose-100'
                  : 'border-border/70 bg-background/70 text-muted-foreground'
            const marker = this.solved
              ? isCorrect
                ? '<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-emerald-700 dark:text-emerald-300">Correct</span>'
                : isSelected
                  ? '<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-rose-700 dark:text-rose-300">Selected</span>'
                  : '<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">Option</span>'
              : '<span class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">Option</span>'

            return `
              <button
                type="button"
                class="answer-button rounded-2xl border px-4 py-4 text-left text-sm text-foreground transition ${solvedStateClasses}"
                data-command="${label.toLowerCase()}"
                ${this.solved ? 'disabled' : ''}
              >
                <div class="mb-2 flex items-center justify-between gap-3">
                  <span class="block font-mono text-[11px] uppercase tracking-[0.2em] text-muted-foreground">${label}</span>
                  ${marker}
                </div>
                <span class="block">${this.escapeHtml(option.name)}</span>
              </button>
            `
          })
          .join('')

        if (this.solved) {
          this.continueButton?.classList.remove('hidden')
        } else {
          this.continueButton?.classList.add('hidden')
        }

        Array.from(this.answerButtons.querySelectorAll<HTMLButtonElement>('.answer-button')).forEach((button) => {
          button.addEventListener('click', () => {
            const command = button.dataset.command
            if (command) this.handleCommand(command)
          })
        })
      }

      renderStats() {
        this.statMode!.textContent = this.modeLabel(this.mode)
        this.statRound!.textContent = String(this.round)
        this.statScore!.textContent = String(this.score)
        this.statStreak!.textContent = String(this.streak)
        this.statAccuracy!.textContent = `${this.overallAccuracy()}%`
        this.statMastered!.textContent = `${this.masteredCount()}/${this.deck.length}`
        this.masteryBar!.style.width = `${this.masteryPercent()}%`
      }

      renderModeButtons() {
        this.modeButtons.forEach((button) => {
          const active = button.dataset.mode === this.mode
          button.classList.toggle('border-amber-300', active)
          button.classList.toggle('bg-amber-100/70', active)
          button.classList.toggle('text-stone-950', active)
          button.classList.toggle('text-muted-foreground', !active)
        })
      }

      renderInspectorButtons() {
        this.inspectorButtons.forEach((button) => {
          const active = button.dataset.inspectorView === this.inspectorView
          button.classList.toggle('border-amber-300', active)
          button.classList.toggle('bg-amber-100/70', active)
          button.classList.toggle('text-stone-950', active)
          button.classList.toggle('text-muted-foreground', !active)
        })
      }

      feedbackMarkup() {
        if (!this.currentCard || !this.solved) return ''

        const isCorrect = this.lastOutcome === 'correct'
        const isSkipped = this.lastOutcome === 'skipped'
        const wrapperClass = isCorrect
          ? 'border-emerald-300 bg-emerald-50/90 dark:border-emerald-800 dark:bg-emerald-950/30'
          : isSkipped
            ? 'border-amber-300 bg-amber-50/90 dark:border-amber-800 dark:bg-amber-950/30'
            : 'border-rose-300 bg-rose-50/90 dark:border-rose-800 dark:bg-rose-950/30'
        const eyebrow = isCorrect ? 'Correct match' : isSkipped ? 'Skipped case' : 'Not quite'
        const summary = isCorrect
          ? 'You identified the right pattern. Lock in why it fits before moving on.'
          : isSkipped
            ? 'The answer is revealed so you can study the pattern without guessing.'
            : 'The answer was nearby, but the reasoning pattern points somewhere more specific.'

        return `
          <div class="rounded-[1.6rem] border ${wrapperClass} p-5">
            <p class="mb-2 font-mono text-[11px] uppercase tracking-[0.24em] text-muted-foreground">${eyebrow}</p>
            <h3 class="m-0 text-xl font-semibold text-foreground">${this.escapeHtml(this.currentCard.name)}</h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">${this.escapeHtml(summary)}</p>
            <div class="mt-4 grid gap-3">
              <div class="rounded-2xl bg-background/70 px-4 py-3 dark:bg-stone-950/50">
                <p class="mb-1 font-medium text-foreground">Why this matches</p>
                <p class="m-0 text-sm leading-6 text-muted-foreground">${this.escapeHtml(this.currentCard.whyItFits)}</p>
              </div>
              <div class="rounded-2xl bg-background/70 px-4 py-3 dark:bg-stone-950/50">
                <p class="mb-1 font-medium text-foreground">Counter-move</p>
                <p class="m-0 text-sm leading-6 text-muted-foreground">${this.escapeHtml(this.currentCard.counter)}</p>
              </div>
            </div>
            ${this.hintUsed ? '<p class="mt-4 mb-0 text-xs text-muted-foreground">Hint was used on this round, so the score bonus was reduced.</p>' : ''}
          </div>
        `
      }

      renderFeedbackCard() {
        if (!this.feedbackCard) return

        if (!this.solved) {
          this.feedbackCard.classList.add('hidden')
          this.feedbackCard.innerHTML = ''
          return
        }

        this.feedbackCard.innerHTML = this.feedbackMarkup()
        this.feedbackCard.classList.remove('hidden')
      }

      focusMarkup(card: StudyCard) {
        const record = this.mastery(card)
        const accuracy = record.seen > 0 ? Math.round((record.correct / record.seen) * 100) : 0
        const sourcesMarkup = card.sources
          .map((source) => {
            return `
              <a
                href="${this.escapeAttribute(source.url)}"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center rounded-full border border-border px-3 py-1 text-xs text-foreground transition hover:border-foreground/20 hover:bg-foreground/[0.04] dark:border-stone-700 dark:hover:border-stone-500 dark:hover:bg-stone-900"
              >
                ${this.escapeHtml(source.label)}
              </a>
            `
          })
          .join('')

        return `
          <div class="space-y-4">
            <div>
              <p class="mb-2 text-xs uppercase tracking-[0.22em] text-muted-foreground">${this.escapeHtml(card.kind)} | ${this.escapeHtml(card.family)}</p>
              <h3 class="m-0 text-2xl font-semibold text-foreground">${this.escapeHtml(card.name)}</h3>
            </div>
            <p class="m-0 text-sm text-muted-foreground">${this.escapeHtml(card.summary)}</p>
            <div class="rounded-2xl border border-border bg-muted/40 p-4 dark:border-stone-800 dark:bg-stone-900/80">
              <p class="mb-2 font-medium text-foreground">Why this card matches</p>
              <p class="m-0 text-sm text-muted-foreground">${this.escapeHtml(card.whyItFits)}</p>
            </div>
            <div class="rounded-2xl border border-border bg-muted/40 p-4 dark:border-stone-800 dark:bg-stone-900/80">
              <p class="mb-2 font-medium text-foreground">Counter-move</p>
              <p class="m-0 text-sm text-muted-foreground">${this.escapeHtml(card.counter)}</p>
            </div>
            <div class="rounded-2xl border border-border bg-muted/40 p-4 dark:border-stone-800 dark:bg-stone-900/80">
              <p class="mb-2 font-medium text-foreground">Source lineage</p>
              <div class="flex flex-wrap gap-2">${sourcesMarkup}</div>
            </div>
            <div class="grid grid-cols-3 gap-3 text-xs text-muted-foreground">
              <div class="rounded-2xl border border-border px-3 py-2 text-center dark:border-stone-800">
                <div class="font-semibold text-foreground">${record.seen}</div>
                <div>Seen</div>
              </div>
              <div class="rounded-2xl border border-border px-3 py-2 text-center dark:border-stone-800">
                <div class="font-semibold text-foreground">${record.correct}</div>
                <div>Correct</div>
              </div>
              <div class="rounded-2xl border border-border px-3 py-2 text-center dark:border-stone-800">
                <div class="font-semibold text-foreground">${accuracy}%</div>
                <div>Accuracy</div>
              </div>
            </div>
          </div>
        `
      }

      renderFocusCard() {
        if (!this.focusCardEl) return
        if (!this.focusCard) {
          this.focusCardEl.innerHTML = '<p class="m-0">Answer a case or open the atlas to pin a concept here.</p>'
          return
        }
        this.focusCardEl.innerHTML = this.focusMarkup(this.focusCard)
      }

      atlasMatches() {
        const query = this.normalize(this.atlasSearch)
        const deck = [...this.deck].sort((a, b) => a.name.localeCompare(b.name))
        if (!query) return deck

        return deck.filter((card) => {
          const haystack = [card.name, card.family, card.kind, card.summary, ...(card.aliases ?? []), ...card.sources.map((source) => source.label)]
            .map((value) => this.normalize(value))
            .join(' ')

          return haystack.includes(query)
        })
      }

      renderAtlas() {
        if (!this.atlasList) return
        const matches = this.atlasMatches()
        const items = matches.slice(0, 80)

        this.atlasList.innerHTML = items
          .map((card) => {
            const active = this.focusCard?.id === card.id
            const record = this.mastery(card)
            const accuracy = record.seen > 0 ? Math.round((record.correct / record.seen) * 100) : 0
            const badgeClass =
              card.kind === 'bias'
                ? 'bg-sky-100 text-sky-900 dark:bg-sky-950/70 dark:text-sky-200'
                : 'bg-amber-100 text-amber-900 dark:bg-amber-950/70 dark:text-amber-200'

            return `
              <button
                type="button"
                class="atlas-item w-full rounded-2xl border px-4 py-3 text-left transition ${
                  active
                    ? 'border-foreground/20 bg-foreground/[0.06] dark:border-amber-200/30 dark:bg-amber-200/10'
                    : 'border-border bg-background hover:border-foreground/20 hover:bg-foreground/[0.03] dark:border-stone-800 dark:bg-stone-950 dark:hover:border-stone-700 dark:hover:bg-stone-900'
                }"
                data-card-id="${card.id}"
              >
                <div class="mb-2 flex items-center justify-between gap-3">
                  <span class="font-medium text-foreground">${this.escapeHtml(card.name)}</span>
                  <span class="rounded-full px-2.5 py-1 text-[11px] font-medium ${badgeClass}">${this.escapeHtml(card.kind)}</span>
                </div>
                <p class="mb-2 text-xs uppercase tracking-[0.18em] text-muted-foreground">${this.escapeHtml(card.family)}</p>
                <p class="m-0 line-clamp-2 text-sm text-muted-foreground">${this.escapeHtml(card.summary)}</p>
                <p class="mt-2 m-0 text-xs text-muted-foreground">Seen ${record.seen} | Accuracy ${accuracy}% | Sources ${card.sources.length}</p>
              </button>
            `
          })
          .join('')

        Array.from(this.atlasList.querySelectorAll<HTMLButtonElement>('.atlas-item')).forEach((button) => {
          button.addEventListener('click', () => {
            const card = this.deck.find((entry) => entry.id === button.dataset.cardId)
            if (!card) return
            this.focusCard = card
            this.inspectorView = 'card'
            this.renderFocusCard()
            this.renderAtlas()
            this.renderInspector()
            this.syncTextState()
          })
        })
      }

      renderInspector() {
        this.cardPanel?.classList.toggle('hidden', this.inspectorView !== 'card')
        this.libraryPanel?.classList.toggle('hidden', this.inspectorView !== 'library')
        this.renderInspectorButtons()
      }

      renderCurrentCase() {
        if (!this.currentFamily || !this.currentScenario || !this.currentCard || !this.currentMeta) return
        this.currentMeta.textContent = `${this.currentCard.kind.toUpperCase()} | ${this.currentCard.family}`
        this.currentScenario.textContent = this.currentCard.scenario
        this.currentFamily.textContent = this.solved
          ? `Resolved as ${this.currentCard.name}. Review the explanation, then continue to the next case.`
          : 'Choose the pattern that best explains the case, then keep the streak moving.'
      }

      render() {
        this.renderLog()
        this.renderButtons()
        this.renderStats()
        this.renderModeButtons()
        this.renderFeedbackCard()
        this.renderFocusCard()
        this.renderAtlas()
        this.renderInspector()
        this.renderCurrentCase()
        this.syncTextState()
      }

      textState() {
        return {
          mode: this.mode,
          inspector_view: this.inspectorView,
          round: this.round,
          score: this.score,
          streak: this.streak,
          best_streak: this.progress.bestStreak,
          mastered: this.masteredCount(),
          accuracy: this.overallAccuracy(),
          solved: this.solved,
          last_outcome: this.lastOutcome,
          current_case: this.currentCard
            ? {
                kind: this.currentCard.kind,
                family: this.currentCard.family,
                scenario: this.currentCard.scenario,
                options: this.currentOptions.map((option, index) => `${LETTERS[index]}. ${option.name}`),
                revealed_answer: this.solved ? this.currentCard.name : null,
              }
            : null,
          focus_card: this.focusCard
            ? {
                name: this.focusCard.name,
                kind: this.focusCard.kind,
                family: this.focusCard.family,
                summary: this.focusCard.summary,
                sources: this.focusCard.sources.map((source) => ({ label: source.label, url: source.url, kind: source.kind })),
              }
            : null,
          atlas_preview: this.atlasMatches()
            .slice(0, 5)
            .map((card) => ({ name: card.name, kind: card.kind, family: card.family })),
          visible_commands: ['a', 'b', 'c', 'd', 'hint', 'explain', 'next', 'skip', 'stats', 'bias', 'fallacy', 'mixed', 'help'],
          coordinate_system: 'Not spatial. State is represented as terminal text, deck mode, and current prompt.',
          virtual_time_ms: this.virtualMs,
        }
      }

      syncTextState() {
        window.render_game_to_text = () => JSON.stringify(this.textState())
        window.advanceTime = (ms: number) => {
          this.virtualMs += ms
          this.render()
        }
        window.__biasFallacyLab = this
      }
    }

    function initBiasFallacyLab() {
      const deckNode = document.getElementById('study-deck-data')
      if (!deckNode?.textContent) return

      const deck = JSON.parse(deckNode.textContent) as StudyCard[]
      new BiasFallacyLab(deck)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initBiasFallacyLab)
    } else {
      initBiasFallacyLab()
    }
  </script>
</BaseLayout>
