---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { ebooks } from '@/data/ebooks'
import { academicPublications, poetryWorks, experimentalWorks } from '@/data/publishing'
---

<BaseLayout
  title="Publishing"
  description="Digital editions, browser-readable texts, and downloadable e-books by Gökhan Turhan."
>
  <div class="publishing-document mx-auto max-w-4xl px-6 py-12 lg:py-16">
    <header class="mb-12">
      <p class="doc-eyebrow mb-3">Publishing</p>
      <h1 class="mb-4 text-3xl font-semibold tracking-tight">Publishing</h1>
      <p class="doc-copy max-w-2xl text-foreground/80">
        Digital editions, browser-readable texts, and downloadable books prepared as quiet web documents.
      </p>
    </header>

    <section id="ebooks" class="border-t border-foreground/15 pt-8">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer list-none border-b border-foreground/10 pb-5">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight">
              <a href="/publishing/ebooks/" class="doc-link">E-books</a>
            </h2>
            <p class="doc-copy mt-2 max-w-xl text-base text-foreground/75">
              Screen-native editions with EPUB downloads, browser reading, and cover art preserved as first-class web assets.
            </p>
          </div>
          <span class="text-foreground/60 transition-transform group-open:rotate-180">▲</span>
        </summary>

        <div class="pt-5">
          <div class="mb-5">
            <a href="/publishing/ebooks/" class="doc-link text-base">
              View library
            </a>
          </div>

          <ul class="space-y-6">
            {ebooks.map((ebook, index) => (
              <li class="grid gap-5 py-2 md:grid-cols-[140px_1fr]">
                <a href={`/publishing/ebooks/${ebook.slug}/`} class="block">
                  <img
                    src={ebook.coverImage}
                    alt={`Cover art for ${ebook.title}`}
                    class="w-full border border-foreground/10 object-cover"
                    loading="lazy"
                  />
                </a>
                <details class="ebook-item group border-b border-foreground/10 pb-4">
                  <p class="doc-eyebrow mb-2">E-book {String(index + 1).padStart(2, '0')}</p>
                  <h3 class="mt-0 text-xl font-semibold">
                    <a href={`/publishing/ebooks/${ebook.slug}/`} class="doc-link">
                      {ebook.title}
                    </a>
                  </h3>
                  <summary class="list-none cursor-pointer mt-1">
                    <p class="mb-2 text-base text-foreground/70">{ebook.subtitle}</p>
                    <span class="ebook-caret text-foreground/60 inline-block">▲</span>
                  </summary>
                  <div class="pt-3">
                    <p class="doc-copy text-lg text-foreground/90">{ebook.blurb}</p>
                    <div class="mt-4 flex flex-wrap gap-4 text-sm text-foreground/60">
                      <span>{ebook.author}</span>
                      <span>{ebook.pageCount} pages</span>
                      <span>{ebook.lineCount} lines</span>
                      <a href={`/publishing/ebooks/${ebook.slug}/`} class="doc-link">View details</a>
                    </div>
                  </div>
                </details>
              </li>
            ))}
          </ul>
        </div>
      </details>
    </section>

    <section id="academic" class="border-t border-foreground/15 pt-10">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer list-none border-b border-foreground/10 pb-5">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight">
              <a href="/publishing/academic/" class="doc-link">Academic</a>
            </h2>
            <p class="doc-copy mt-2 max-w-xl text-base text-foreground/75">
              Selected publications, chapters, and graduate work.
            </p>
          </div>
          <span class="text-foreground/60 transition-transform group-open:rotate-180">▲</span>
        </summary>

        <ul class="pt-6 space-y-6">
          {academicPublications.map((item) => (
            <li class="border-b border-foreground/10 pb-5">
              <p class="doc-eyebrow mb-2">{item.type}</p>
              <h3 class="mt-0 text-xl font-semibold leading-tight">
                <a href={item.href} class="doc-link" target="_blank" rel="noopener noreferrer">
                  {item.title}
                </a>
              </h3>
              <p class="mb-3 text-base text-foreground/70">
                {item.venue} · {item.year}
              </p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-foreground/60">
                <span>{item.author}</span>
                <a href={item.href} class="doc-link" target="_blank" rel="noopener noreferrer">
                  {item.linkLabel}
                </a>
              </div>
            </li>
          ))}
        </ul>
      </details>
    </section>

    <section id="poetry" class="border-t border-foreground/15 pt-10">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer list-none border-b border-foreground/10 pb-5">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight">
              <a href="/publishing/poetry/" class="doc-link">Poetry</a>
            </h2>
            <p class="doc-copy mt-2 max-w-xl text-base text-foreground/75">
              Visual poetry works and publication references.
            </p>
          </div>
          <span class="text-foreground/60 transition-transform group-open:rotate-180">▲</span>
        </summary>

        <ul class="pt-6 space-y-6">
          {poetryWorks.map((work) => (
            <li class="grid gap-5 py-2 md:grid-cols-[140px_1fr]">
              <a href={work.sourceHref} class="block" target="_blank" rel="noopener noreferrer">
                <img
                  src={work.coverImage}
                  alt={work.coverAlt}
                  class="w-full border border-foreground/10 object-cover"
                  loading="lazy"
                />
              </a>
              <div>
                <p class="doc-eyebrow mb-2">{work.type}</p>
                <h3 class="mt-0 text-xl font-semibold leading-tight">
                  <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                    {work.title}
                  </a>
                </h3>
                <p class="mb-3 text-base text-foreground/70">
                  {work.creators} · {work.year}
                </p>
                <div class="flex flex-wrap items-center gap-4 text-sm text-foreground/60">
                  <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                    Read on Xexoxial
                  </a>
                  <a href={work.amazonHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                    Amazon (opens Amazon)
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </details>
    </section>

    <section id="experimental" class="border-t border-foreground/15 pt-10">
      <details class="group" open>
        <summary class="flex items-center justify-between cursor-pointer list-none border-b border-foreground/10 pb-5">
          <div>
            <h2 class="text-2xl font-semibold tracking-tight">
              <a href="/publishing/experimental/" class="doc-link">Experimental</a>
            </h2>
            <p class="doc-copy mt-2 max-w-xl text-base text-foreground/75">
              Sound-led and hybrid experiments across writing, recording, and networked media.
            </p>
          </div>
          <span class="text-foreground/60 transition-transform group-open:rotate-180">▲</span>
        </summary>

        <ul class="pt-6 space-y-6">
          {experimentalWorks.map((work) => (
            <li class="grid gap-5 py-2 md:grid-cols-[140px_1fr]">
              <a href={work.detailHref} class="block">
                <img
                  src={work.coverImage}
                  alt={work.coverAlt}
                  class="w-full border border-foreground/10 object-cover"
                  loading="lazy"
                />
              </a>
              <div>
                <p class="doc-eyebrow mb-2">{work.type}</p>
                <h3 class="mt-0 text-xl font-semibold leading-tight">
                  <a href={work.detailHref} class="doc-link">
                    {work.title}
                  </a>
                </h3>
                <p class="mb-3 text-base text-foreground/70">
                  {work.creators} · {work.year}
                </p>
                <p class="mb-3 text-base text-foreground/75">
                  Commissioned by <a href={work.commissionedByHref} class="doc-link" target="_blank" rel="noopener noreferrer">{work.commissionedByName}</a>.
                </p>
                <p class="doc-copy mb-4 text-sm text-foreground/65">
                  {work.zoraStatusNote}
                </p>
                <p class="doc-copy mb-4 text-base text-foreground/85">
                  {work.accompanyingText}
                </p>
                <audio controls preload="none" class="w-full max-w-xl">
                  <source src={work.audioHref} type={work.audioMimeType} />
                </audio>
                <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-foreground/60">
                  <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                    View on Zora
                  </a>
                  <a href={work.originalAudioHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                    Original audio source
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </details>
    </section>
  </div>
</BaseLayout>

<style>
  .publishing-document {
    color: #171717;
    font-family: Georgia, "Times New Roman", serif;
  }

  .publishing-document .doc-eyebrow {
    color: #666;
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .publishing-document .doc-copy {
    line-height: 1.38;
  }

  .publishing-document .doc-link {
    color: #1a0dab;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .publishing-document .doc-link:visited {
    color: #551a8b;
  }

  .publishing-document details summary::-webkit-details-marker {
    display: none;
  }

  .publishing-document details summary::marker {
    display: none;
  }

  .publishing-document .ebook-item > summary .ebook-caret {
    transition: transform 160ms ease;
  }

  .publishing-document .ebook-item[open] > summary .ebook-caret {
    transform: rotate(180deg);
  }
</style>
