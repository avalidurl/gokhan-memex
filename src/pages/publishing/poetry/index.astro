---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { poetryWorks } from '@/data/publishing'
---

<BaseLayout
  title="Poetry"
  description="Visual poetry works and publication references by Gökhan Turhan."
>
  <div class="publishing-document mx-auto max-w-4xl px-6 py-12 lg:py-16">
    <header class="mb-12">
      <p class="doc-eyebrow mb-3">Publishing / Poetry</p>
      <h1 class="mb-4 text-3xl font-semibold tracking-tight">Poetry</h1>
      <p class="doc-copy max-w-2xl text-foreground/80">
        Visual poetry works and publication references.
      </p>
    </header>

    <div class="space-y-8">
      {poetryWorks.map((work) => (
        <article class="grid gap-6 border-t border-foreground/15 pt-8 md:grid-cols-[220px_1fr]">
          <a href={work.sourceHref} class="block" target="_blank" rel="noopener noreferrer">
            <img
              src={work.coverImage}
              alt={work.coverAlt}
              class="w-full border border-foreground/10 object-cover"
              loading="lazy"
            />
          </a>

          <div class="flex flex-col">
            <p class="doc-eyebrow mb-3">{work.type}</p>
            <h2 class="mt-0 text-2xl font-semibold tracking-tight leading-tight">
              <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                {work.title}
              </a>
            </h2>
            <p class="mb-4 text-base text-foreground/70">
              {work.creators} · {work.year}
            </p>

            <div class="mt-auto flex flex-wrap gap-x-5 gap-y-2 text-base">
              <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                Read on Xexoxial
              </a>
              <a href={work.amazonHref} class="doc-link" target="_blank" rel="noopener noreferrer">
                Amazon (opens Amazon)
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .publishing-document {
    color: #171717;
    font-family: Georgia, "Times New Roman", serif;
  }

  .publishing-document .doc-eyebrow {
    color: #666;
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .publishing-document .doc-copy {
    line-height: 1.38;
  }

  .publishing-document .doc-link {
    color: #1a0dab;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .publishing-document .doc-link:visited {
    color: #551a8b;
  }
</style>
