---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { ebooks } from '@/data/ebooks'
---

<BaseLayout
  title="E-books"
  description="Downloadable EPUBs and browser-readable digital books by Gökhan Turhan."
>
  <div class="mx-auto max-w-4xl px-6 py-12 lg:py-16">
    <Breadcrumbs items={[{ label: 'Publishing', href: '/publishing/' }]} currentPage="E-books" />

    <header class="mb-12">
      <p class="mb-3 text-sm uppercase tracking-[0.28em] text-muted-foreground">Publishing / E-books</p>
      <h1 class="mb-4 text-3xl font-semibold tracking-tight">E-books</h1>
      <p class="max-w-2xl text-muted-foreground">
        Browser-readable editions and downloadable EPUB files, prepared as static Cloudflare-served assets.
      </p>
    </header>

    <div class="space-y-8">
      {ebooks.map((ebook, index) => (
        <article class="grid gap-6 rounded-3xl border border-border/70 bg-card/40 p-6 shadow-sm shadow-black/5 md:grid-cols-[220px_1fr]">
          <a href={`/publishing/ebooks/${ebook.slug}/`} class="block">
            <img
              src={ebook.coverImage}
              alt={`Cover art for ${ebook.title}`}
              class="w-full rounded-2xl border border-border/70 bg-muted/20 object-cover shadow-sm"
              loading="lazy"
            />
          </a>

          <div class="flex flex-col">
            <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs uppercase tracking-[0.2em] text-muted-foreground">
              <span>E-book {String(index + 1).padStart(2, '0')}</span>
              <span>{ebook.pageCount} pages</span>
              <span>{new Date(ebook.publishedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>

            <h2 class="mt-0 text-2xl font-semibold tracking-tight">
              <a href={`/publishing/ebooks/${ebook.slug}/`} class="hover:underline decoration-1 underline-offset-4">
                {ebook.title}
              </a>
            </h2>
            <p class="mb-3 text-base text-muted-foreground">{ebook.subtitle}</p>
            <p class="mb-6 max-w-2xl text-foreground/90">{ebook.blurb}</p>

            <div class="mt-auto flex flex-wrap gap-3">
              <a
                href={ebook.browserEditionUrl}
                class="inline-flex items-center justify-center rounded-full border border-foreground/15 px-5 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/25 hover:bg-foreground/5"
              >
                Open HTML
              </a>
              <a
                href={ebook.epubUrl}
                class="inline-flex items-center justify-center rounded-full border border-border bg-muted/20 px-5 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/20 hover:bg-muted/40"
                download
              >
                Download EPUB
              </a>
              <a
                href={`/publishing/ebooks/${ebook.slug}/`}
                class="inline-flex items-center justify-center rounded-full px-2 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
              >
                View details
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
