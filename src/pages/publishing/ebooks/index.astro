---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { ebooks } from '@/data/ebooks'
---

<BaseLayout
  title="E-books"
  description="Downloadable EPUBs and browser-readable digital books by Gökhan Turhan."
>
  <div class="publishing-document mx-auto max-w-4xl px-6 py-12 lg:py-16">
    <header class="mb-12">
      <p class="doc-eyebrow mb-3">Publishing / E-books</p>
      <h1 class="mb-4 text-3xl font-semibold tracking-tight">E-books</h1>
      <p class="doc-copy max-w-2xl text-foreground/80">
        Browser-readable editions and downloadable EPUB files prepared as readable, printable web documents.
      </p>
    </header>

    <div class="space-y-8">
      {ebooks.map((ebook, index) => (
        <article class="grid gap-6 border-t border-foreground/15 pt-8 md:grid-cols-[220px_1fr]">
          <a href={`/publishing/ebooks/${ebook.slug}/`} class="block">
            <img
              src={ebook.coverImage}
              alt={`Cover art for ${ebook.title}`}
              class="w-full border border-foreground/10 object-cover"
              loading="lazy"
            />
          </a>

          <div class="flex flex-col">
            <details class="group">
              <summary class="list-none cursor-pointer">
                <div class="doc-eyebrow mb-4 flex flex-wrap items-center gap-x-4 gap-y-2">
                  <span>E-book {String(index + 1).padStart(2, '0')}</span>
                  <span>{ebook.pageCount} pages</span>
                  <span>{new Date(ebook.publishedOn).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                </div>
                <h2 class="mt-0 text-2xl font-semibold tracking-tight doc-link inline">{ebook.title}</h2>
                <p class="mb-2 text-base text-foreground/70">{ebook.subtitle}</p>
                <span class="ebook-caret text-foreground/60 inline-block">▲</span>
              </summary>

              <p class="doc-copy mb-6 max-w-2xl text-lg text-foreground/90 pt-3">{ebook.blurb}</p>

              <div class="mt-auto flex flex-wrap gap-x-5 gap-y-2 text-base">
                <a
                  href={ebook.browserEditionUrl}
                  class="doc-link"
                >
                  Open HTML
                </a>
                <a
                  href={ebook.epubUrl}
                  class="doc-link"
                  download
                >
                  Download EPUB
                </a>
                <a
                  href={`/publishing/ebooks/${ebook.slug}/`}
                  class="doc-link"
                >
                  View details
                </a>
              </div>
            </details>
            </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .publishing-document {
    color: #171717;
    font-family: Georgia, "Times New Roman", serif;
  }

  .publishing-document .doc-eyebrow {
    color: #666;
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .publishing-document .doc-copy {
    line-height: 1.38;
  }

  .publishing-document .doc-link {
    color: #1a0dab;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .publishing-document .doc-link:visited {
    color: #551a8b;
  }

  .publishing-document .ebook-caret {
    transition: transform 160ms ease;
  }

  .publishing-document details[open] .ebook-caret {
    transform: rotate(180deg);
  }
</style>
