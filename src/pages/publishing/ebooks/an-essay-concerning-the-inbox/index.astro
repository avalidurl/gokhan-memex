---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import { getEbookBySlug } from '@/data/ebooks'

const ebook = getEbookBySlug('an-essay-concerning-the-inbox')

if (!ebook) {
  throw new Error('E-book metadata not found.')
}

const publishedLabel = new Date(ebook.publishedOn).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={ebook.title}
  description={ebook.description}
  image={ebook.coverImage}
>
  <div class="mx-auto max-w-5xl px-6 py-12 lg:py-16">
    <Breadcrumbs
      items={[
        { label: 'Publishing', href: '/publishing/' },
        { label: 'E-books', href: '/publishing/ebooks/' },
      ]}
      currentPage={ebook.title}
    />

    <section class="grid gap-8 lg:grid-cols-[320px_1fr] lg:items-start">
      <div class="lg:sticky lg:top-24">
        <img
          src={ebook.coverImage}
          alt={`Cover art for ${ebook.title}`}
          class="w-full rounded-[2rem] border border-border/70 bg-muted/20 object-cover shadow-lg shadow-black/10"
        />
      </div>

      <div>
        <p class="mb-3 text-sm uppercase tracking-[0.28em] text-muted-foreground">Publishing / E-books</p>
        <h1 class="mb-4 text-4xl font-semibold tracking-tight">{ebook.title}</h1>
        <p class="mb-5 max-w-2xl text-lg text-muted-foreground">{ebook.subtitle}</p>

        <div class="mb-6 flex flex-wrap gap-x-5 gap-y-2 text-sm text-muted-foreground">
          <span>{ebook.author}</span>
          <span>{publishedLabel}</span>
          <span>{ebook.pageCount} pages</span>
          <span>{ebook.lineCount} lines</span>
        </div>

        <p class="max-w-3xl text-base text-foreground/90">{ebook.blurb}</p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={ebook.browserEditionUrl}
            class="inline-flex items-center justify-center rounded-full border border-foreground/15 px-5 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/25 hover:bg-foreground/5"
          >
            Open HTML edition
          </a>
          <a
            href={ebook.epubUrl}
            class="inline-flex items-center justify-center rounded-full border border-border bg-muted/20 px-5 py-2.5 text-sm font-medium text-foreground transition-colors hover:border-foreground/20 hover:bg-muted/40"
            download
          >
            Download EPUB
          </a>
          <a
            href={ebook.staticHtmlUrl}
            class="inline-flex items-center justify-center rounded-full px-2 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
            target="_blank"
            rel="noopener"
          >
            Raw HTML export
          </a>
        </div>
      </div>
    </section>

    <section class="mt-14">
      <div class="max-w-3xl rounded-3xl border border-border/70 bg-card/40 p-6 shadow-sm shadow-black/5">
        <p class="mb-3 text-xs uppercase tracking-[0.22em] text-muted-foreground">Info</p>
        <p class="mb-0 text-lg leading-8 text-foreground/90">
          {ebook.blurb}
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
