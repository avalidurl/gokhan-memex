---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { experimentalWorks } from '@/data/publishing'

const work = experimentalWorks.find((entry) => entry.detailHref === '/publishing/experimental/casette/')

if (!work) {
  throw new Error('CASSETTE entry not found in experimentalWorks')
}
---

<BaseLayout
  title="CASSETTE"
  description="Full cover and accompanying information text for CASSETTE by Gökhan Turhan."
>
  <div class="publishing-document mx-auto max-w-5xl px-6 py-12 lg:py-16">
    <header class="mb-12">
      <p class="doc-eyebrow mb-3">Publishing / Experimental / CASSETTE</p>
      <h1 class="mb-4 text-3xl font-semibold tracking-tight">{work.title}</h1>
      <p class="doc-copy max-w-3xl text-foreground/80">
        {work.creators} · {work.year}
      </p>
    </header>

    <article class="space-y-8 border-t border-foreground/15 pt-8">
      <img
        src={work.coverImage}
        alt={work.coverAlt}
        class="w-full border border-foreground/10 object-cover"
        loading="eager"
      />

      {work.commissionedByName && work.commissionedByHref && (
        <p class="text-base text-foreground/75">
          Commissioned by <a href={work.commissionedByHref} class="doc-link" target="_blank" rel="noopener noreferrer">{work.commissionedByName}</a>.
        </p>
      )}
      {work.statusNote && <p class="doc-copy text-sm text-foreground/65">{work.statusNote}</p>}

      {(work.sourceHref || work.originalAudioHref) && (
        <div class="flex flex-wrap gap-x-5 gap-y-2 text-base">
          {work.sourceHref && (
            <a href={work.sourceHref} class="doc-link" target="_blank" rel="noopener noreferrer">
              {work.sourceLabel ?? 'View source'}
            </a>
          )}
          {work.originalAudioHref && (
            <a href={work.originalAudioHref} class="doc-link" target="_blank" rel="noopener noreferrer">
              {work.originalAudioLabel ?? 'Original source'}
            </a>
          )}
        </div>
      )}

      {work.audioHref && work.audioMimeType && (
        <audio controls preload="none" class="w-full max-w-2xl">
          <source src={work.audioHref} type={work.audioMimeType} />
        </audio>
      )}

      <h2 class="text-2xl font-semibold tracking-tight">Information text</h2>
      <div class="space-y-4">
        {work.accompanyingText.split('\n\n').map((paragraph) => (
          <p class="doc-copy text-base text-foreground/90">{paragraph}</p>
        ))}
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .publishing-document {
    color: #171717;
    font-family: Georgia, "Times New Roman", serif;
  }

  .publishing-document .doc-eyebrow {
    color: #666;
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .publishing-document .doc-copy {
    line-height: 1.38;
  }

  .publishing-document .doc-link {
    color: #1a0dab;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .publishing-document .doc-link:visited {
    color: #551a8b;
  }
</style>
