---
/**
 * Dedicated tight one-page CV layout, optimized for PDF generation.
 * Not linked in nav; rendered to public/cv/Gokhan_Turhan_CV.pdf via headless Chrome.
 * Source of truth is src/data/cv.ts — keep this purely presentational.
 */
import {
  cvMeta,
  contact,
  profile,
  experience,
  education,
  publications,
  skillGroups,
  languages,
} from '@/data/cv'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{cvMeta.name} — CV</title>
    <style is:inline>
      @page { size: A4; margin: 0; }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: #fff; }
      body {
        font-family: Georgia, 'Times New Roman', serif;
        color: #1b1b1b;
        font-size: 6.8pt;
        line-height: 1.22;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page { width: 210mm; padding: 9mm 11mm; }

      .head h1 {
        margin: 0;
        font-size: 17pt;
        letter-spacing: -0.01em;
        line-height: 1.05;
      }
      .head .title {
        margin: 2px 0 0;
        font-size: 8pt;
        font-style: italic;
        color: #333;
      }
      .head .tagline {
        margin: 2px 0 0;
        font-size: 6.8pt;
        color: #333;
        max-width: 100%;
      }
      .rule { border-top: 1.4px solid #222; margin: 5px 0 6px; }

      .cols { display: grid; grid-template-columns: 33% 1fr; gap: 12px; }
      .sidebar { font-size: 6.4pt; }

      h2.sec {
        margin: 0 0 2.5px;
        font-size: 7.4pt;
        font-weight: bold;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border-bottom: 0.6px solid #b5b5b5;
        padding-bottom: 1.5px;
      }
      section { margin-bottom: 5.5px; }
      ul { margin: 2px 0 0; padding-left: 10px; }
      li { margin: 1px 0; }

      /* sidebar */
      .contact { list-style: none; margin: 0; padding: 0; }
      .contact li { margin: 1.4px 0; }
      .contact .lbl { color: #777; }
      .sg { margin-bottom: 5px; }
      .sg h3 {
        margin: 0 0 1px;
        font-size: 6.2pt;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #555;
      }
      .sg p { margin: 0; }
      .langs { margin: 0; }

      /* main */
      .profile p { margin: 0 0 3px; }
      .job { margin-bottom: 4px; }
      .job .top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 8px;
      }
      .job h3 { margin: 0; font-size: 7.6pt; font-weight: bold; }
      .job h3 .org { font-weight: normal; }
      .job .dates { font-size: 7pt; color: #666; white-space: nowrap; }
      .job .loc { font-size: 7pt; color: #666; font-style: italic; }
      .job ul { margin-top: 2px; }

      .edu li { list-style: none; margin: 0 0 4px; }
      .edu .deg { font-weight: bold; }
      .edu .meta { color: #555; }
      a { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="head">
        <h1>{cvMeta.name}</h1>
        <p class="title">{cvMeta.title}</p>
        <p class="tagline">{cvMeta.tagline}</p>
      </header>
      <div class="rule"></div>

      <div class="cols">
        <aside class="sidebar">
          <section>
            <h2 class="sec">Contact</h2>
            <ul class="contact">
              {contact.map((c) => (
                <li><span class="lbl">{c.label}:</span> {c.value}</li>
              ))}
            </ul>
          </section>

          <section>
            <h2 class="sec">Skills &amp; tooling</h2>
            {skillGroups.map((g) => (
              <div class="sg">
                <h3>{g.name}</h3>
                <p>{g.items.join(' · ')}</p>
              </div>
            ))}
          </section>

          <section>
            <h2 class="sec">Languages</h2>
            <p class="langs">
              {languages.map((l) => `${l.name} (${l.level})`).join(' · ')}
            </p>
          </section>
        </aside>

        <main class="main">
          <section class="profile">
            <h2 class="sec">Profile</h2>
            {profile.map((p) => <p>{p}</p>)}
          </section>

          <section>
            <h2 class="sec">Experience</h2>
            {experience.map((job) => (
              <div class="job">
                <div class="top">
                  <h3>{job.role}<span class="org"> — {job.org}</span></h3>
                  <span class="dates">{job.start} – {job.end}</span>
                </div>
                {job.location && <div class="loc">{job.location}</div>}
                <ul>
                  {job.bullets.map((b) => <li>{b}</li>)}
                </ul>
              </div>
            ))}
          </section>

          <section>
            <h2 class="sec">Education</h2>
            <ul class="edu">
              {education.map((ed) => (
                <li>
                  <span class="deg">{ed.degree}{'honors' in ed && ed.honors ? ` — ${ed.honors}` : ''}</span>
                  {' · '}<span class="meta">{ed.school} ({ed.years})</span>
                  {'detail' in ed && ed.detail && <div class="meta">{ed.detail}</div>}
                </li>
              ))}
            </ul>
          </section>

          <section>
            <h2 class="sec">Publications &amp; exhibitions</h2>
            <ul>
              {publications.map((p) => <li>{p}</li>)}
            </ul>
          </section>
        </main>
      </div>
    </div>
  </body>
</html>
