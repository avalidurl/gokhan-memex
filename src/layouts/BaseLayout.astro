---
import { createHash } from 'node:crypto'
import { readFileSync } from 'node:fs'
import { resolve } from 'node:path'
import '@fontsource-variable/jetbrains-mono'
import Navigation from '@/components/Navigation.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import ThemeProvider from '@/components/ThemeProvider.astro'
import PrivacyNotice from '@/components/PrivacyNotice.astro'
import OfflineStatus from '@/components/OfflineStatus.astro'
import FooterSubscribe from '@/components/FooterSubscribe.astro'
import { getAutoBreadcrumbs, type BreadcrumbItem } from '@/lib/breadcrumbs'
import '@/styles/globals.css'
import criticalStyles from '@/styles/critical.css?inline'

export interface Props {
  title: string
  description: string
  image?: string
  canonicalURL?: string
  type?: 'website' | 'article'
  robots?: string
  /** Hide breadcrumbs (default: show on all pages except home). */
  showBreadcrumbs?: boolean
  /** Full breadcrumb trail; overrides auto-detection from URL + title. */
  breadcrumbOverride?: { items: BreadcrumbItem[]; currentPage: string }
  /** Hide footer subscribe when journal in-flow block is shown. */
  hideFooterSubscribe?: boolean
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  type = 'website',
  robots = 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1',
  showBreadcrumbs = true,
  breadcrumbOverride,
  hideFooterSubscribe = false,
} = Astro.props

const siteName = 'Gökhan Turhan'
const fullTitle = title === siteName ? title : `${title} | ${siteName}`

const pathname = Astro.url.pathname
const breadcrumbData =
  showBreadcrumbs && (breadcrumbOverride ?? getAutoBreadcrumbs(pathname, title))

// Document register — every surface files under a section number.
const docSection = pathname.split('/').filter(Boolean)[0] ?? ''
const docMap: Record<string, string> = {
  '': 'MX-001',
  journal: 'MX-010',
  archive: 'MX-020',
  writing: 'MX-030',
  publishing: 'MX-040',
  projects: 'MX-050',
  art: 'MX-060',
  lists: 'MX-070',
  links: 'MX-080',
  haleanbar: 'MX-085',
  cv: 'MX-090',
  consulting: 'MX-091',
  privacy: 'MX-095',
  disclaimer: 'MX-096',
  offline: 'MX-098',
  '404': 'MX-099',
}
const docNo = docMap[docSection] ?? 'MX-000'
const docRev = 'REV 2026-07-17'

/** Content hash of the collapse script, so an edit busts the 2h asset cache for every
 *  visitor. HTML is served max-age=0, so a changed ?v= always lands immediately. */
const collapseVersion = createHash('sha256')
  .update(readFileSync(resolve(process.cwd(), 'public/blog-collapse.js')))
  .digest('hex')
  .slice(0, 8)
---

<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Theme: the OS preference is handled entirely in CSS (prefers-color-scheme
         in the inlined critical styles), so no JS is needed for the default.
         This script only stamps an explicit stored choice; data-cfasync keeps
         Rocket Loader from deferring it past first paint. -->
    <script is:inline data-cfasync="false">
      const t = localStorage.getItem('theme');
      if (t === 'dark' || t === 'light') document.documentElement.classList.add(t);
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots.includes('noindex') ? 'noindex, follow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:site_name" content={siteName} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@goekhan" />
    <meta name="twitter:creator" content="@goekhan" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    
    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    
    <!-- PWA Meta Tags -->
    <meta name="application-name" content={siteName} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="msapplication-TileColor" content="#f4f4f2" />
    <meta name="theme-color" content="#f4f4f2" />
    
    <!-- Apple Touch Icons — root paths by convention (and outside the /icons/* edge cleanup rule) -->
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    
    <!-- Substack DNS prefetch for faster iframe loading -->
    <link rel="dns-prefetch" href="https://gokhan.substack.com" />
    <link rel="preconnect" href="https://gokhan.substack.com" />
    
    <!-- Critical CSS - Inlined for First Contentful Paint Optimization -->
    <style is:inline set:html={criticalStyles}></style>
    
    <!-- Google Analytics - Load by Default -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-TSMR6G8LLL"></script>
    <script is:inline>
      // Initialize dataLayer and gtag function
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      
      // Initialize GA with timestamp
      gtag('js', new Date());
      
      // Check if user has opted out
      const privacyChoice = localStorage.getItem('privacy-choice');
      
      if (privacyChoice === 'declined') {
        // User has opted out - disable tracking
        gtag('config', 'G-TSMR6G8LLL', {
          'anonymize_ip': true,
          'allow_google_signals': false,
          'allow_ad_personalization_signals': false,
          'send_page_view': false
        });
      } else {
        // Default behavior - track all users
        gtag('config', 'G-TSMR6G8LLL', {
          'anonymize_ip': true,
          'allow_google_signals': false,
          'allow_ad_personalization_signals': false
        });
      }
      
      // Expose functions globally for privacy notice component
      window.enableGoogleAnalytics = function() {
        gtag('config', 'G-TSMR6G8LLL', {
          'anonymize_ip': true,
          'allow_google_signals': false,
          'allow_ad_personalization_signals': false
        });
        // Send current page view if it was disabled
        gtag('event', 'page_view', {
          page_title: document.title,
          page_location: window.location.href
        });
      };
      
      window.disableGoogleAnalytics = function() {
        gtag('config', 'G-TSMR6G8LLL', {
          'anonymize_ip': true,
          'allow_google_signals': false,
          'allow_ad_personalization_signals': false,
          'send_page_view': false
        });
      };
    </script>
    
    <!-- Structured Data - Person Schema -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Gökhan Turhan",
      "alternateName": "goekhan",
      "description": "T-shaped generalist founder, researcher, and Strategic Innovation Architect operating across fintech, deep tech, competitive governance, art markets, and investment strategies. His work sits at the junction of stablecoins, real-world assets, tokenization, cryptography, AGI timelines, and global systemic challenges—turning them into high-leverage opportunities through foresight, product growth strategy, and technology expertise.",
      "jobTitle": ["Strategic Innovation Architect", "Founder", "Researcher", "Conceptual Artist"],
      "url": "https://gokhanturhan.com",
      "sameAs": [
        "https://x.com/goekhan",
        "https://github.com/avalidurl",
        "https://linkedin.com/in/goekhanturhan",
        "https://warpcast.com/gokhan",
        "https://gokhan.substack.com",
        "https://t.me/goekhanturhan"
      ],
      "knowsAbout": [
        "Stablecoins", "Real World Assets", "RWA", "Tokenization", "Cryptography", 
        "Artificial General Intelligence", "AGI timelines", "Investment Strategy", 
        "Fintech", "Deep Tech", "Art Markets", "Information Markets", "Sabermetrics",
        "Competitive Governance", "Global Systemic Challenges", "Strategic Innovation",
        "Product Growth Strategy", "Technology Expertise", "Foresight"
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Strategic Innovation Architect",
        "description": "Turning global systemic challenges into high-leverage opportunities through foresight, product growth strategy, and technology expertise across fintech and deep tech"
      }
    })} />

    <!-- Per-page head content passed via slot="head" (Article JSON-LD, custom schemas, seoKeywords meta). -->
    <slot name="head" />
  </head>

  <body class="min-h-screen font-sans">
    <p class="nrbar">
      <span class="nrbar-flag">We are raising</span>
      <span class="nrbar-note">— check our decks:</span>
      <a class="nrbar-link" href="https://ishtar.numetal.xyz/deck/not-raising-a-preseed/">Ishtar deck</a>
      <span class="nrbar-note" aria-hidden="true">·</span>
      <a class="nrbar-link" href="https://curb.numetal.xyz/deck">Curb deck</a>
    </p>
    <ThemeProvider />
    <div class="site-sheet relative flex min-h-screen flex-col">
      <Navigation docNo={docNo} docRev={docRev} />

      <main class="flex-1">
        {breadcrumbData && (
          <div class="mx-auto max-w-5xl px-6 pt-6 lg:px-8">
            <Breadcrumbs items={breadcrumbData.items} currentPage={breadcrumbData.currentPage} />
          </div>
        )}
        <slot />
      </main>
      
      <!-- Footer -->
      <footer class="mt-auto px-6 py-8">
        <div class="mx-auto max-w-2xl">
          {
            !hideFooterSubscribe && <FooterSubscribe />
          }
          <div class="flex flex-col gap-3 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
            <span>© {new Date().getFullYear()} Gökhan Turhan</span>
            <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
              <a href="/rss.xml" class="raw-link">RSS</a>
              <a href="/privacy" class="raw-link">Privacy</a>
              <a href="/disclaimer" class="raw-link">Disclaimer</a>
            </div>
          </div>
          <div class="perforation" style="margin-top:1.4rem" aria-hidden="true"></div>
          <div class="colophon" style="margin-top:0.6rem">
            <span>GT MEMEX · DOC {docNo} · {docRev}</span>
            <span>PERSONAL RECORD — CONTENTS AS FILED</span>
          </div>
        </div>
      </footer>
    </div>
    
    <!-- Privacy Notice -->
    <PrivacyNotice />
    
    <!-- Offline Status Indicator -->
    <OfflineStatus />
    
    <!-- Lightbox for images - click to enlarge -->
    <div id="lightbox" style="display:none;position:fixed;inset:0;background:var(--paper);z-index:9999;cursor:zoom-out;overflow:auto" onclick="this.style.display='none'">
      <img id="lightbox-img" style="max-width:95%;max-height:95%;margin:auto;display:block;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);border:2px solid var(--ink)" />
      <span style="position:fixed;top:20px;right:30px;color:var(--ink);font-size:40px;cursor:pointer">&times;</span>
    </div>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        document.querySelectorAll('article img, .prose img').forEach(img => {
          img.style.cursor = 'zoom-in';
          img.addEventListener('click', (e) => {
            e.preventDefault();
            lightboxImg.src = img.src;
            lightbox.style.display = 'block';
          });
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') lightbox.style.display = 'none';
        });
      });
    </script>
    <!-- Collapsible article headings (blog/journal only; no-ops elsewhere). -->
    <script src={`/blog-collapse.js?v=${collapseVersion}`} defer></script>
  </body>
</html>

<style>
  /* Raise notice — same ruled row as the gokhan.vc masthead treatment. */
  .nrbar {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.6ch;
    margin: 0;
    max-width: none;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-bottom: 2px solid var(--ink);
  }
  .nrbar-flag { font-weight: 700; }
  .nrbar-note { color: var(--dim); }
  .nrbar-link { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
</style>
