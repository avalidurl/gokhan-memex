---
import BaseLayout from '@/layouts/BaseLayout.astro'
import type { Ebook } from '@/data/ebooks'
import { loadEbookLines, paginateEbookLines } from '@/lib/ebook-reader'

const { ebook } = Astro.props as { ebook: Ebook }

const lines = loadEbookLines(ebook)
const pages = paginateEbookLines(lines, ebook.linesPerPage)
const pageJumpLinks = pages.filter((page) => page.pageNumber === 1 || page.pageNumber % 5 === 0)
const cantoStartLines = new Map(ebook.toc.map((entry) => [entry.startLine, entry]))
---

<BaseLayout
  title={`${ebook.title} | Read Online`}
  description={`Read ${ebook.title} online in HTML with page-numbered sections.`}
  image={ebook.coverImage}
  breadcrumbOverride={{
    items: [
      { label: 'Publishing', href: '/publishing/' },
      { label: 'E-books', href: '/publishing/ebooks/' },
      { label: ebook.title, href: `/publishing/ebooks/${ebook.slug}/` },
    ],
    currentPage: 'Read online',
  }}
>
  <div id="top" class="reader-document mx-auto max-w-5xl px-6 py-12 lg:py-16">
    <section class="border-t border-foreground/15 pt-8">
      <div class="grid gap-8 lg:grid-cols-[240px_1fr]">
        <img
          src={ebook.coverImage}
          alt={`Cover art for ${ebook.title}`}
          class="w-full border border-foreground/10 object-cover"
        />

        <div>
          <p class="doc-eyebrow mb-3">Online Reader</p>
          <h1 class="mb-4 text-4xl font-semibold tracking-tight">{ebook.title}</h1>
          <p class="mb-4 max-w-2xl text-lg text-foreground/70">{ebook.subtitle}</p>
          <p class="doc-copy mb-6 text-lg text-foreground/90">{ebook.blurb}</p>

          <div class="mb-8 flex flex-wrap gap-x-5 gap-y-2 text-sm text-foreground/60">
            <span>By {ebook.author}</span>
            <span>{ebook.pageCount} pages</span>
            <span>{ebook.lineCount} numbered lines</span>
          </div>

          <div class="border-t border-foreground/15 py-5">
            <p class="doc-eyebrow mb-2">Inside cover</p>
            <p class="mb-1 text-xl font-semibold text-foreground">{ebook.title}</p>
            <p class="mb-1 text-foreground/70">{ebook.subtitle}</p>
            <p class="mb-0 text-sm text-foreground/90">{ebook.author}</p>
            {ebook.website ? <p class="mb-0 text-sm text-foreground/90">{ebook.website}</p> : null}
          </div>

          <div class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-base">
            <a
              href={ebook.epubUrl}
              class="doc-link"
              download
            >
              Download EPUB
            </a>
            <a
              href={ebook.staticHtmlUrl}
              class="doc-link"
              target="_blank"
              rel="noopener"
            >
              Raw HTML export
            </a>
            {ebook.sourceTextUrl ? (
              <a
                href={ebook.sourceTextUrl}
                class="doc-link"
                download
              >
                Download source text
              </a>
            ) : null}
          </div>
        </div>
      </div>
    </section>

    <nav class="mt-10 border-t border-foreground/15 pt-6">
      <p class="doc-eyebrow mb-3">Page numbers</p>
      <div class="flex flex-wrap gap-x-4 gap-y-2 text-base">
        {pageJumpLinks.map((page) => (
          <a
            href={`#page-${page.pageNumber}`}
            class="doc-link"
          >
            Page {page.pageNumber}
          </a>
        ))}
      </div>
    </nav>

    <nav class="mt-8 border-t border-foreground/15 pt-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight">Table of Contents</h2>
      <ol class="space-y-2 pl-6 text-base leading-7 text-foreground/90">
        {ebook.toc.map((entry) => (
          <li>
            <a href={`#${entry.anchor}`} class="doc-link">
              {entry.number}. {entry.title}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <div class="mt-10 space-y-8">
      {pages.map((page) => (
        <section
          id={`page-${page.pageNumber}`}
          class="border-t border-foreground/15 py-8"
        >
          <div class="flex items-center justify-between gap-4 border-b border-foreground/10 pb-4">
            <div>
              <p class="doc-eyebrow mb-1">Page {page.pageNumber}</p>
              <p class="text-sm text-foreground/60">
                Lines {String(page.lines[0]?.number ?? 0).padStart(4, '0')} to {String(page.lines[page.lines.length - 1]?.number ?? 0).padStart(4, '0')}
              </p>
            </div>
            <a href="#top" class="doc-link text-sm">Back to top</a>
          </div>

          <div class="mt-6 space-y-3">
            {page.lines.map((line) => {
              const cantoEntry = cantoStartLines.get(line.number)

              return (
                <div class="space-y-3">
                  {cantoEntry ? (
                    <div id={cantoEntry.anchor} class="mb-1 scroll-mt-24 border-b border-foreground/10 pb-3">
                      <p class="doc-eyebrow mb-1">Canto {cantoEntry.number}</p>
                      <h2 class="text-2xl font-semibold tracking-tight">{cantoEntry.title}</h2>
                    </div>
                  ) : null}
                  <p class="grid grid-cols-[3.75rem_1fr] gap-4 text-base leading-[1.34]">
                    <span class="doc-line-number">{String(line.number).padStart(4, '0')}</span>
                    <span>{line.text}</span>
                  </p>
                </div>
              )
            })}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .reader-document {
    color: #171717;
    font-family: Georgia, "Times New Roman", serif;
  }

  .reader-document .doc-eyebrow {
    color: #666;
    font-family: "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .reader-document .doc-copy {
    line-height: 1.38;
  }

  .reader-document .doc-link {
    color: #1a0dab;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
  }

  .reader-document .doc-link:visited {
    color: #551a8b;
  }

  .reader-document .doc-line-number {
    color: #6f6f6f;
    font-family: "Courier New", monospace;
    font-size: 0.88rem;
    min-width: 3.75rem;
  }

  @media (max-width: 640px) {
    .reader-document .doc-line-number {
      font-size: 0.8rem;
    }
  }
</style>
