---
import { Menu, X, Search } from 'lucide-astro'
import ThemeToggle from './ThemeToggle.astro'
import SearchComponent from './Search.astro'

const currentPath = Astro.url.pathname
const isArticle = currentPath.startsWith('/journal/') && currentPath !== '/journal/' && currentPath !== '/journal'

const navigation = [
  { name: 'Journal', href: '/journal' },
  { name: 'Archive', href: '/archive' },
  { name: 'Lists', href: '/lists' },
  { name: 'Publishing', href: '/publishing' },
  { name: 'CV', href: '/cv' },
  { name: 'Contact', href: '/subscribe' }
]
---

<header class="sticky top-0 z-50 w-full bg-background/95 backdrop-blur-sm supports-[backdrop-filter]:bg-background/80">
  <div class="mx-auto max-w-5xl px-6 lg:px-8">
    <div class="flex h-14 items-center justify-between">
      <!-- Left side: Logo/Name or Back button -->
      <div class="flex items-center">
        {isArticle ? (
          <a 
            href="/journal" 
            class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors"
            aria-label="Back to Journal"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span class="text-sm font-medium hidden sm:inline">Close</span>
          </a>
        ) : (
          <a 
            class="font-serif text-lg tracking-tight text-foreground hover:text-foreground/80 transition-colors" 
            href="/"
          >
            Gökhan Turhan
          </a>
        )}
      </div>

      <!-- Center: Navigation Links (Desktop only, not on article pages) -->
      {!isArticle && (
        <nav class="hidden md:flex items-center gap-8">
          {navigation.map((item) => (
            <a
              href={item.href}
              class={`text-sm transition-colors ${
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-foreground font-medium' 
                  : 'text-muted-foreground hover:text-foreground'
              }`}
            >
              {item.name}
            </a>
          ))}
        </nav>
      )}

      <!-- Right side: Actions -->
      <div class="flex items-center gap-1">
        <!-- Search Button -->
        <button 
          id="search-button"
          class="p-2 text-muted-foreground hover:text-foreground transition-colors rounded-md hover:bg-muted/50"
          aria-label="Search"
        >
          <Search class="h-4 w-4" />
        </button>
        
        <!-- Theme Toggle -->
        <ThemeToggle />

        <!-- Mobile Menu Button (not on article pages) -->
        {!isArticle && (
          <button
            id="mobile-menu-button"
            class="inline-flex rounded-md p-2 text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground md:hidden"
            aria-label="Toggle menu"
            aria-controls="mobile-menu"
            aria-expanded="false"
            type="button"
          >
            <Menu id="menu-icon" class="h-5 w-5" />
            <X id="close-icon" class="hidden h-5 w-5" />
          </button>
        )}
      </div>
    </div>
  </div>
</header>

{!isArticle && (
  <div
    id="mobile-menu"
    class="fixed inset-x-0 top-14 bottom-0 z-50 hidden overflow-y-auto bg-background md:hidden"
    aria-hidden="true"
  >
    <nav class="flex flex-col px-6 py-6">
      {navigation.map((item) => (
        <a
          href={item.href}
          class={`mobile-menu-link border-b border-border/30 py-4 text-xl transition-colors ${
            currentPath === item.href || currentPath.startsWith(item.href + '/')
              ? 'text-foreground font-medium'
              : 'text-muted-foreground hover:text-foreground'
          }`}
        >
          {item.name}
        </a>
      ))}
      <a
        href="/rss.xml"
        class="mobile-menu-link py-4 text-xl text-muted-foreground transition-colors hover:text-foreground"
      >
        RSS Feed
      </a>
    </nav>
  </div>
)}

<!-- Search Modal -->
<SearchComponent />

<script is:inline>
  (() => {
    function initNavigation() {
      const button = document.getElementById('mobile-menu-button')
      const menu = document.getElementById('mobile-menu')
      const menuIcon = document.getElementById('menu-icon')
      const closeIcon = document.getElementById('close-icon')

      if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return
      if (button.dataset.initialized === 'true') return
      button.dataset.initialized = 'true'

      const setOpen = (open) => {
        button.setAttribute('aria-expanded', open ? 'true' : 'false')
        menu.setAttribute('aria-hidden', open ? 'false' : 'true')
        menu.classList.toggle('hidden', !open)
        menuIcon?.classList.toggle('hidden', open)
        closeIcon?.classList.toggle('hidden', !open)
        document.body.style.overflow = open ? 'hidden' : ''
      }

      setOpen(false)

      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true'
        setOpen(!isOpen)
      })

      menu.querySelectorAll('.mobile-menu-link').forEach((link) => {
        link.addEventListener('click', () => setOpen(false))
      })

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') setOpen(false)
      })

      window.addEventListener('pageshow', () => setOpen(false))
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initNavigation, { once: true })
    } else {
      initNavigation()
    }

    document.addEventListener('astro:page-load', initNavigation)
  })()
</script>
