function leafCount(tile: Tile): number {
  return (
    (tile.cta ? 1 : 0) +
    tile.tools.length +
    (tile.socials?.length ?? 0) +
    (tile.contact ? 1 : 0)
  )
}

function leafAttrs(leaf: Leaf) {
  return leaf.ext ? { target: '_blank', rel: 'noopener noreferrer' } : {}
}
---

<section class="board-section" aria-labelledby="board-title">
  <p class="board-stamp" id="board-title">Board · six tiles, one person</p>

  <div class="kanban-board" role="list">
    {
      tiles.map((tile, index) => (
        <article class="kanban-col" role="listitem">
          <details class="board-details">
            <summary class="board-header" id={`tile-${tile.id}`}>
              <span class="board-meta" aria-hidden="true">
                <span class="board-index">{String(index + 1).padStart(2, '0')}</span>
                <span class="board-count">{leafCount(tile)} links</span>
              </span>
              <span class="board-summary">
                <span class="board-label">{tile.label}</span>
                <span class="board-domain">{tile.domain}</span>
                <span class="board-owner">{tile.owner}</span>
              </span>
              <span class="board-toggle" aria-hidden="true">
                <span class="board-toggle-open">Open</span>
                <span class="board-toggle-close">Close</span>
                <span class="board-chevron" />
              </span>
            </summary>
            <div class="board-body" aria-labelledby={`tile-${tile.id}`}>
              {tile.blurb && <p class="board-blurb">{tile.blurb}</p>}
              {tile.cta && (
                <a
                  class="board-cta"
                  href={tile.cta.href}
                  download={tile.cta.download}
                  {...leafAttrs(tile.cta)}
                >
                  <span class="board-cta-label">{tile.cta.platform}</span>
                  <span class="board-cta-note">{tile.cta.note}{tile.cta.download ? ' ↓' : tile.cta.ext ? ' ↗' : ' →'}</span>
                </a>
              )}
              <ul class="leaves" role="list">
                {tile.tools.map((leaf) => (
                  <li class="leaf">
                    <a class="leaf-link" href={leaf.href} {...leafAttrs(leaf)}>
                      <span class="leaf-platform">{leaf.platform}</span>
                      <span class="leaf-note">{leaf.note}</span>
                    </a>
                  </li>
                ))}
                {tile.socials && tile.socials.length > 0 && (
                  <li class="leaf-heading">
                    <h3 class="socials-heading">{tile.socialsLabel ?? 'Socials'}</h3>
                  </li>
                )}
                {(tile.socials ?? []).map((leaf) => (
                  <li class="leaf">
                    <a class="leaf-link" href={leaf.href} {...leafAttrs(leaf)}>
                      <span class="leaf-platform">{leaf.platform}</span>
                      <span class="leaf-note">{leaf.note}</span>
                    </a>
                  </li>
                ))}
                {tile.contact && (
                  <li class="leaf leaf-contact">
                    <a class="leaf-link" href={tile.contact.href}>
                      <span class="leaf-platform">{tile.contact.platform}</span>
                      <span class="leaf-note">{tile.contact.note}</span>
                    </a>
                  </li>
                )}
              </ul>
            </div>
          </details>
        </article>
      ))
    }
  </div>
</section>

<style>
  .board-section {
    width: 100%;
  }

  .board-stamp {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 0 0 18px;
    text-align: center;
  }

  .kanban-board {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    align-items: stretch;
  }

  @media (min-width: 640px) {
    .kanban-board {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .kanban-board {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .kanban-col {
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  /* Bordered plate, no resting shadow — the agentbounty index-plate read.
     Depth arrives only on hover, as a flat blue underlay (no blur, no ink). */
  .board-details {
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    border: 2px solid hsl(var(--foreground));
    background: hsl(var(--card));
    transition: box-shadow 80ms ease-out;
  }

  .board-details:hover,
  .board-details:focus-within {
    background: hsl(var(--card));
  }

  .board-header {
    position: relative;
    margin: 0;
    padding: 14px;
    list-style: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    flex: 1;
  }

  .board-details:not([open]) .board-header > :last-child {
    margin-top: auto;
  }

  .board-details[open] > .board-header {
    border-bottom: 2px solid hsl(var(--foreground));
  }

  .board-header::-webkit-details-marker,
  .board-header::marker {
    display: none;
  }

  .board-header:hover {
    background: var(--faint);
  }

  .board-header:focus-visible {
    outline: 2px solid hsl(var(--foreground));
    outline-offset: 2px;
  }

  .board-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .board-index {
    color: var(--dim);
    font-weight: 700;
  }

  .board-count {
    color: hsl(var(--muted-foreground));
  }

  .board-summary {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .board-label {
    font-weight: 700;
    letter-spacing: 0.01em;
    color: hsl(var(--foreground));
    overflow-wrap: anywhere;
    font-size: 19px;
  }

  .board-domain {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: hsl(var(--foreground));
    overflow-wrap: anywhere;
  }

  .board-owner {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: hsl(var(--muted-foreground));
    line-height: 1.5;
    /* reserve two lines so collapsed faces stay equal across the row */
    min-height: 3em;
  }

  .board-toggle {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--foreground));
  }

  .board-toggle-close {
    display: none;
  }

  .board-details[open] > .board-header .board-toggle-open {
    display: none;
  }

  .board-details[open] > .board-header .board-toggle-close {
    display: inline;
  }

  .board-chevron {
    display: none;
  }

  .board-details[open] > .board-header .board-chevron {
    transform: rotate(-135deg);
    margin-bottom: -2px;
  }

  .board-body {
    padding: 0 14px 14px;
  }

  .board-blurb {
    margin: 12px 0 0;
    font-size: 13.5px;
    line-height: 1.55;
    color: hsl(var(--foreground));
    border-left: 2px solid var(--ink);
    padding-left: 12px;
  }

  /* Primary action button — inverted ink plate, e.g. Generate CV. */
  .board-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3px;
    margin: 14px 0 2px;
    padding: 9px 12px;
    border: 2px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
  }

  .board-cta:hover,
  .board-cta:focus-visible {
    background: var(--paper);
    color: var(--ink);
  }

  .board-cta-label {
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .board-cta-note {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .leaves {
    list-style: none;
    margin: 10px 0 0;
    padding: 0 0 0 8px;
    position: relative;
    border-left: 2px solid hsl(var(--border));
  }

  .leaf {
    position: relative;
    padding: 4px 0 4px 20px;
  }

  .leaf::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 50%;
    width: 14px;
    border-top: 2px solid hsl(var(--border));
  }

  .leaf-heading {
    list-style: none;
    padding: 14px 0 4px 20px;
    position: relative;
  }

  .leaf-heading::before {
    content: '';
    position: absolute;
    left: -2px;
    top: 50%;
    width: 14px;
    border-top: 2px solid hsl(var(--border));
  }

  .socials-heading {
    margin: 0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: hsl(var(--foreground));
  }

  .leaf-contact {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed hsl(var(--border));
  }

  .leaf-contact::before {
    display: none;
  }

  .leaf-link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
    max-width: 100%;
    padding: 3px 8px;
    border: 2px solid transparent;
    text-decoration: none;
    transition:
      box-shadow 80ms ease-out,
      border-color 80ms ease-out,
      background 80ms ease-out;
  }

  .leaf-platform {
    font-weight: 700;
    font-size: 13px;
    color: hsl(var(--foreground));
  }

  .leaf-note {
    font-family: var(--font-mono);
    font-size: 11px;
    color: hsl(var(--muted-foreground));
    overflow-wrap: anywhere;
    line-height: 1.35;
  }

  .leaf-link:hover,
  .leaf-link:focus-visible {
    background: var(--faint);
    border-color: var(--ink);
  }

  .leaf-link:hover .leaf-platform,
  .leaf-link:focus-visible .leaf-platform {
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
  }

  .leaf-link:focus-visible {
    outline: 2px solid hsl(var(--foreground));
    outline-offset: 2px;
  }
</style>
