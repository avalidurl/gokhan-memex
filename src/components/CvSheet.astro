---
/**
 * Shared tight one-page CV layout (two-column).
 * Embedded on /cv/ as a print-only block. The downloadable PDF is generated by
 * printing /cv/ itself, so "Download PDF" and the browser's Print are identical
 * by construction (same DOM, same CSS environment).
 * Source of truth for the data is src/data/cv.ts — keep this purely presentational.
 */
import {
  cvMeta,
  contact,
  profile,
  experience,
  education,
  publications,
  skillGroups,
  languages,
} from '@/data/cv'
---

<div class="cv-sheet">
  <div class="page">
    <div class="head">
      <h1>{cvMeta.name}</h1>
      <p class="title">{cvMeta.title}</p>
      <p class="tagline">{cvMeta.tagline}</p>
    </div>
    <div class="rule"></div>

    <div class="cols">
      <div class="sidebar">
        <section>
          <h2 class="sec">Contact</h2>
          <ul class="contact">
            {contact.map((c) => (
              <li><span class="lbl">{c.label}:</span> {c.value}</li>
            ))}
          </ul>
        </section>

        <section>
          <h2 class="sec">Skills &amp; tooling</h2>
          {skillGroups.map((g) => (
            <div class="sg">
              <h3>{g.name}</h3>
              <p>{g.items.join(' · ')}</p>
            </div>
          ))}
        </section>

        <section>
          <h2 class="sec">Languages</h2>
          <p class="langs">
            {languages.map((l) => `${l.name} (${l.level})`).join(' · ')}
          </p>
        </section>
      </div>

      <div class="main">
        <section class="profile">
          <h2 class="sec">Profile</h2>
          {profile.map((p) => <p>{p}</p>)}
        </section>

        <section>
          <h2 class="sec">Experience</h2>
          {experience.map((job) => (
            <div class="job">
              <div class="top">
                <h3>{job.role}<span class="org"> — {job.org}</span></h3>
                <span class="dates">{job.start} – {job.end}</span>
              </div>
              {job.location && <div class="loc">{job.location}</div>}
              <ul>
                {job.bullets.map((b) => <li>{b}</li>)}
              </ul>
            </div>
          ))}
        </section>

        <section>
          <h2 class="sec">Education</h2>
          <ul class="edu">
            {education.map((ed) => (
              <li>
                <span class="deg">{ed.degree}{'honors' in ed && ed.honors ? ` — ${ed.honors}` : ''}</span>
                {' · '}<span class="meta">{ed.school} ({ed.years})</span>
                {'detail' in ed && ed.detail && <div class="meta">{ed.detail}</div>}
              </li>
            ))}
          </ul>
        </section>

        <section>
          <h2 class="sec">Publications &amp; exhibitions</h2>
          <ul>
            {publications.map((p) => <li>{p}</li>)}
          </ul>
        </section>
      </div>
    </div>
  </div>
</div>

<style is:global>
  @page { size: A4; margin: 0; }
</style>

<style>
  .cv-sheet {
    background: #fff;
    color: #1b1b1b;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 6.8pt;
    line-height: 1.22;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  .cv-sheet * { box-sizing: border-box; }
  .cv-sheet .page { width: 210mm; padding: 9mm 11mm; }

  .cv-sheet .head h1 {
    margin: 0;
    font-size: 17pt;
    letter-spacing: -0.01em;
    line-height: 1.05;
  }
  .cv-sheet .head .title { margin: 2px 0 0; font-size: 8pt; font-style: italic; color: #333; }
  .cv-sheet .head .tagline { margin: 2px 0 0; font-size: 6.8pt; color: #333; max-width: 100%; }
  .cv-sheet .rule { border-top: 1.4px solid #222; margin: 5px 0 6px; }

  .cv-sheet .cols { display: grid; grid-template-columns: 33% 1fr; gap: 12px; }
  .cv-sheet .sidebar { font-size: 6.4pt; }

  .cv-sheet h2.sec {
    margin: 0 0 2.5px;
    font-size: 7.4pt;
    font-weight: bold;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-bottom: 0.6px solid #b5b5b5;
    padding-bottom: 1.5px;
  }
  .cv-sheet section { margin-bottom: 5.5px; }
  /* explicit list rendering so it survives any ambient CSS reset (e.g. Tailwind preflight) */
  .cv-sheet ul { margin: 2px 0 0; padding-left: 10px; list-style: none; }
  .cv-sheet li { margin: 1px 0; }
  .cv-sheet .main ul { list-style: disc; }
  .cv-sheet .main .edu li { list-style: none; }

  .cv-sheet .contact { list-style: none; margin: 0; padding: 0; }
  .cv-sheet .contact li { margin: 1.4px 0; }
  .cv-sheet .contact .lbl { color: #777; }
  .cv-sheet .sg { margin-bottom: 5px; }
  .cv-sheet .sg h3 {
    margin: 0 0 1px;
    font-size: 6.2pt;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #555;
  }
  .cv-sheet .sg p { margin: 0; }
  .cv-sheet .langs { margin: 0; }

  .cv-sheet .profile p { margin: 0 0 3px; }
  .cv-sheet .job { margin-bottom: 4px; }
  .cv-sheet .job .top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }
  .cv-sheet .job h3 { margin: 0; font-size: 7.6pt; font-weight: bold; }
  .cv-sheet .job h3 .org { font-weight: normal; }
  .cv-sheet .job .dates { font-size: 7pt; color: #666; white-space: nowrap; }
  .cv-sheet .job .loc { font-size: 7pt; color: #666; font-style: italic; }
  .cv-sheet .job ul { margin-top: 2px; }

  .cv-sheet .edu li { list-style: none; margin: 0 0 4px; }
  .cv-sheet .edu .deg { font-weight: bold; }
  .cv-sheet .edu .meta { color: #555; }
  .cv-sheet a { color: inherit; text-decoration: none; }
</style>
