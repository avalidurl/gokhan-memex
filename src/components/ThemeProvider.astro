---
// Theme provider for dark mode support
---

<script>
  // Saved choice is stamped as a class; with no saved choice, no class —
  // the OS preference applies through CSS (prefers-color-scheme) alone.
  const theme = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
  const el = document.documentElement;
  if (theme === 'dark') {
    el.classList.add('dark');
    el.classList.remove('light');
  } else if (theme === 'light') {
    el.classList.add('light');
    el.classList.remove('dark');
  } else {
    el.classList.remove('dark');
    el.classList.remove('light');
  }
</script>
