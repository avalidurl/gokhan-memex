---
export interface Props {
  url: string;
  artist?: string;
  title?: string;
  className?: string;
}

const { url, artist, title, className = "" } = Astro.props;

// Detect platform from URL
function getPlatformInfo(url: string) {
  const domain = new URL(url).hostname.toLowerCase();
  
  if (domain.includes('sound.xyz')) {
    return {
      name: 'Sound.xyz',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  if (domain.includes('catalog.works')) {
    return {
      name: 'Catalog',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  if (domain.includes('bandcamp.com')) {
    return {
      name: 'Bandcamp',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  if (domain.includes('spotify.com')) {
    return {
      name: 'Spotify',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  if (domain.includes('apple.com') || domain.includes('music.apple.com')) {
    return {
      name: 'Apple Music',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  if (domain.includes('youtube.com') || domain.includes('youtu.be')) {
    return {
      name: 'YouTube',
      icon: '',
      color: 'bg-background border-border text-foreground'
    };
  }
  
  return {
    name: 'Music Link',
    icon: '',
    color: 'bg-background border-border text-foreground'
  };
}

const platform = getPlatformInfo(url);
---

<a 
  href={url} 
  target="_blank" 
  rel="noopener noreferrer"
  class={`inline-flex items-center gap-3 p-4 border-2 no-underline hover:no-underline ${platform.color} ${className}`}
  style="text-decoration: none !important;"
>
    <div class="flex-1">
    <div class="flex items-center gap-2 text-sm font-medium opacity-75">
      <span>{platform.name}</span>
<span aria-hidden="true">↗</span>
    </div>
    {(artist || title) && (
      <div class="mt-1">
        {artist && <span class="font-semibold">{artist}</span>}
        {artist && title && <span class="mx-2">—</span>}
        {title && <span>"{title}"</span>}
      </div>
    )}
    {!artist && !title && (
      <div class="text-sm opacity-75 mt-1 font-mono truncate">
        {url.replace(/^https?:\/\//, '')}
      </div>
    )}
  </div>
</a>